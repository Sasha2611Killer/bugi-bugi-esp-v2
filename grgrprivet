local ESP = {}
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- Настройки ESP
ESP.Settings = {
    Enabled = true,
    EspBox = true,
    EspName = true,
    EspHealthBar = true,
    EspHealthText = true,
    BoxColor = Color3.fromRGB(255, 0, 0),
    NameColor = Color3.fromRGB(255, 255, 255),
    HealthBarWidth = 6,
    OutlineColor = Color3.fromRGB(0, 0, 0),
    Transparency = 1,
    ShowTeammates = false,
    ShowEnemies = true,
    ShowSelf = false,
    BoxThickness = 1.6,
    MaxRenderDistance = 1000, -- Максимальная дистанция отрисовки
}

-- Внутренние переменные
local Boxes = {}
local Names = {}
local HealthBars = {}
local HealthTexts = {}
local Humanoids = {}
local Connections = {}
local PlayerData = {}

-- Кэш для оптимизации
local Vector2new = Vector2.new
local Color3fromRGB = Color3.fromRGB
local math_min = math.min
local math_max = math.max
local math_abs = math.abs
local math_floor = math.floor
local tick = tick
local pairs = pairs
local continue = continue -- для луау

-- Функция для проверки, враг ли игрок
local function IsEnemy(plr)
    if plr == LocalPlayer then 
        return ESP.Settings.ShowSelf
    end

    local myChar = LocalPlayer.Character
    local theirChar = plr.Character
    if not myChar or not theirChar then return false end

    local isEnemy = myChar.Parent.Name ~= theirChar.Parent.Name

    if isEnemy then
        return ESP.Settings.ShowEnemies
    else
        return ESP.Settings.ShowTeammates
    end
end

-- Функция для получения Humanoid
local function GetHumanoid(character)
    if not character then return nil end
    for _, child in pairs(character:GetChildren()) do
        if child:IsA("Humanoid") then
            return child
        end
    end
    return nil
end

-- Очистка данных игрока
local function ClearPlayerData(plr)
    Humanoids[plr] = nil
    PlayerData[plr] = nil

    if Boxes[plr] then
        Boxes[plr].Visible = false
    end
    if Names[plr] then
        Names[plr].Visible = false
    end
    if HealthBars[plr] then
        if HealthBars[plr].bg then
            HealthBars[plr].bg.Visible = false
        end
        if HealthBars[plr].fill then
            HealthBars[plr].fill.Visible = false
        end
    end
    if HealthTexts[plr] then
        HealthTexts[plr].Visible = false
    end
end

-- Обновление Humanoid
local function UpdateHumanoid(plr)
    local char = plr.Character
    if char then
        local newHumanoid = GetHumanoid(char)
        if newHumanoid then
            Humanoids[plr] = newHumanoid
            PlayerData[plr] = {
                lastUpdate = tick(),
                valid = true
            }
            return true
        end
    end

    ClearPlayerData(plr)
    return false
end

-- Очистка соединений
local function ClearConnections(plr)
    if Connections[plr] then
        for _, conn in pairs(Connections[plr]) do
            conn:Disconnect()
        end
        Connections[plr] = nil
    end
end

-- Спрятать весь ESP для игрока
local function HideAllESP(plr)
    if Boxes[plr] then
        Boxes[plr].Visible = false
    end
    if Names[plr] then
        Names[plr].Visible = false
    end
    if HealthBars[plr] then
        if HealthBars[plr].bg then
            HealthBars[plr].bg.Visible = false
        end
        if HealthBars[plr].fill then
            HealthBars[plr].fill.Visible = false
        end
    end
    if HealthTexts[plr] then
        HealthTexts[plr].Visible = false
    end
end

-- Проверка, находится ли точка на экране (ОПТИМИЗИРОВАНО)
local function IsOnScreen(position)
    local screenPoint = Camera:WorldToViewportPoint(position)
    -- Проверяем, что точка перед камерой и в пределах экрана
    return screenPoint.Z > 0 and screenPoint.Z < ESP.Settings.MaxRenderDistance 
           and screenPoint.X >= 0 and screenPoint.X <= Camera.ViewportSize.X
           and screenPoint.Y >= 0 and screenPoint.Y <= Camera.ViewportSize.Y
end

-- Создание ESP для игрока
local function CreateESP(plr)
    if Boxes[plr] then return end

    -- Create box
    local box = Drawing.new("Square")
    box.Thickness = ESP.Settings.BoxThickness
    box.Filled = false
    box.Color = ESP.Settings.BoxColor
    box.Transparency = ESP.Settings.Transparency
    box.Visible = false
    Boxes[plr] = box

    -- Create name tag
    local nameTag = Drawing.new("Text")
    nameTag.Text = plr.Name
    nameTag.Size = 16
    nameTag.Color = ESP.Settings.NameColor
    nameTag.Center = true
    nameTag.Outline = true
    nameTag.OutlineColor = ESP.Settings.OutlineColor
    nameTag.Visible = false
    Names[plr] = nameTag

    -- Create health bar background
    local healthBarBg = Drawing.new("Square")
    healthBarBg.Thickness = 1
    healthBarBg.Filled = true
    healthBarBg.Color = Color3fromRGB(0, 0, 0)
    healthBarBg.Transparency = 0.7
    healthBarBg.Visible = false
    HealthBars[plr] = {bg = healthBarBg, fill = nil}

    -- Create health bar fill
    local healthBarFill = Drawing.new("Square")
    healthBarFill.Thickness = 1
    healthBarFill.Filled = true
    healthBarFill.Color = Color3fromRGB(0, 255, 0)
    healthBarFill.Transparency = 0.7
    healthBarFill.Visible = false
    HealthBars[plr].fill = healthBarFill

    -- Create health text
    local healthText = Drawing.new("Text")
    healthText.Size = 14
    healthText.Color = Color3fromRGB(255, 255, 255)
    healthText.Center = true
    healthText.Outline = true
    healthText.OutlineColor = ESP.Settings.OutlineColor
    healthText.Visible = false
    HealthTexts[plr] = healthText
end

-- Удаление ESP для игрока
local function RemoveESP(plr)
    if Boxes[plr] then
        Boxes[plr]:Remove()
        Boxes[plr] = nil
    end
    if Names[plr] then
        Names[plr]:Remove()
        Names[plr] = nil
    end
    if HealthBars[plr] then
        if HealthBars[plr].bg then
            HealthBars[plr].bg:Remove()
        end
        if HealthBars[plr].fill then
            HealthBars[plr].fill:Remove()
        end
        HealthBars[plr] = nil
    end
    if HealthTexts[plr] then
        HealthTexts[plr]:Remove()
        HealthTexts[plr] = nil
    end

    ClearPlayerData(plr)
    ClearConnections(plr)
end

-- Получение цвета здоровья
local function GetHealthColor(percent)
    percent = math_max(0, math_min(1, percent))
    
    if percent > 0.6 then
        return Color3fromRGB(0, 255, 0)
    elseif percent > 0.3 then
        return Color3fromRGB(255, 255, 0)
    elseif percent > 0.1 then
        return Color3fromRGB(255, 100, 0)
    else
        return Color3fromRGB(255, 0, 0)
    end
end

-- Безопасное получение значений здоровья
local function GetSafeHealthValues(humanoid)
    if not humanoid then
        return 0, 100
    end

    local maxHealth = 100
    local success, result = pcall(function()
        return humanoid.MaxHealth
    end)
    if success and result and result > 0 then
        maxHealth = result
    end

    local health = 0
    success, result = pcall(function()
        return humanoid.Health
    end)
    if success and result and result >= 0 then
        health = result
    end

    if health > maxHealth * 2 then
        health = maxHealth
    end

    return health, maxHealth
end

-- Функция для обновления цвета полоски здоровья
local function UpdateHealthBarColor(plr, healthPercent)
    if not HealthBars[plr] or not HealthBars[plr].fill then return end
    
    local fillBar = HealthBars[plr].fill
    fillBar.Color = GetHealthColor(healthPercent)
    fillBar.Visible = fillBar.Visible
end

-- Отслеживание смерти и изменений здоровья
local function TrackDeath(plr, humanoid)
    if not humanoid then return end

    local healthChangedConn = humanoid:GetPropertyChangedSignal("Health"):Connect(function()
        if Humanoids[plr] == humanoid then
            local health, maxHealth = GetSafeHealthValues(humanoid)
            if maxHealth > 0 then
                UpdateHealthBarColor(plr, health / maxHealth)
            end
        end
    end)
    
    if not Connections[plr] then
        Connections[plr] = {}
    end
    table.insert(Connections[plr], healthChangedConn)

    local diedConn
    diedConn = humanoid.Died:Connect(function()
        ClearPlayerData(plr)

        task.wait(1)

        if plr.Character then
            UpdateHumanoid(plr)
        end

        if diedConn then
            diedConn:Disconnect()
        end
    end)
    table.insert(Connections[plr], diedConn)
end

-- Обработка добавления персонажа
local function OnCharacterAdded(plr, char)
    ClearPlayerData(plr)
    ClearConnections(plr)

    Connections[plr] = {}

    task.wait(0.5)

    UpdateHumanoid(plr)

    local humanoid = Humanoids[plr]
    if humanoid then
        TrackDeath(plr, humanoid)
        
        local health, maxHealth = GetSafeHealthValues(humanoid)
        if maxHealth > 0 then
            UpdateHealthBarColor(plr, health / maxHealth)
        end
    end

    local childAddedConn = char.ChildAdded:Connect(function(child)
        if child:IsA("Humanoid") then
            UpdateHumanoid(plr)
            TrackDeath(plr, child)
            
            local health, maxHealth = GetSafeHealthValues(child)
            if maxHealth > 0 then
                UpdateHealthBarColor(plr, health / maxHealth)
            end
        end
    end)
    table.insert(Connections[plr], childAddedConn)

    local childRemovedConn = char.ChildRemoved:Connect(function(child)
        if child:IsA("Humanoid") then
            ClearPlayerData(plr)
        end
    end)
    table.insert(Connections[plr], childRemovedConn)

    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        local hrpChangedConn = hrp:GetPropertyChangedSignal("Parent"):Connect(function()
            if not hrp.Parent then
                ClearPlayerData(plr)
            end
        end)
        table.insert(Connections[plr], hrpChangedConn)
    end

    local charAncestryChangedConn = char.AncestryChanged:Connect(function()
        if not char.Parent then
            ClearPlayerData(plr)
        end
    end)
    table.insert(Connections[plr], charAncestryChangedConn)
end

-- Обработка добавления игрока
local function OnPlayerAdded(plr)
    if plr == LocalPlayer and not ESP.Settings.ShowSelf then 
        return 
    end

    CreateESP(plr)

    local charAddedConn = plr.CharacterAdded:Connect(function(char)
        OnCharacterAdded(plr, char)
    end)

    if not Connections[plr] then
        Connections[plr] = {}
    end
    table.insert(Connections[plr], charAddedConn)

    local charRemovingConn = plr.CharacterRemoving:Connect(function()
        ClearPlayerData(plr)
    end)
    table.insert(Connections[plr], charRemovingConn)

    if plr.Character then
        OnCharacterAdded(plr, plr.Character)
    end
end

-- Отслеживаем изменения в настройках
local SettingsMetatable = {
    __newindex = function(t, key, value)
        rawset(t, key, value)

        if key == "BoxColor" or key == "BoxThickness" then
            for _, box in pairs(Boxes) do
                if box then
                    box.Color = ESP.Settings.BoxColor
                    box.Thickness = ESP.Settings.BoxThickness
                end
            end
        elseif key == "NameColor" or key == "OutlineColor" then
            for _, nameTag in pairs(Names) do
                if nameTag then
                    nameTag.Color = ESP.Settings.NameColor
                    nameTag.OutlineColor = ESP.Settings.OutlineColor
                end
            end
            for _, healthText in pairs(HealthTexts) do
                if healthText then
                    healthText.OutlineColor = ESP.Settings.OutlineColor
                end
            end
        end
    end
}

setmetatable(ESP.Settings, SettingsMetatable)

-- Оптимизированный основной цикл обновления
RunService.RenderStepped:Connect(function()
    -- Быстрая проверка глобального состояния
    if not ESP.Settings.Enabled then
        -- Если ESP выключен, быстро прячем всё
        for plr, _ in pairs(Boxes) do
            HideAllESP(plr)
        end
        return
    end

    local viewportSize = Camera.ViewportSize
    
    for plr, box in pairs(Boxes) do
        -- Пропускаем себя если не нужно показывать
        if plr == LocalPlayer and not ESP.Settings.ShowSelf then
            HideAllESP(plr)
            continue
        end

        local nameTag = Names[plr]
        local healthBar = HealthBars[plr]
        local healthText = HealthTexts[plr]
        local char = plr.Character

        -- Быстрая проверка персонажа
        if not char or not char.Parent then
            ClearPlayerData(plr)
            continue
        end

        -- Получаем части с кэшированием
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local head = char:FindFirstChild("Head")

        if not hrp or not head then
            HideAllESP(plr)
            continue
        end

        -- Проверка на врага
        if not IsEnemy(plr) then
            HideAllESP(plr)
            continue
        end

        -- Получаем Humanoid
        local humanoid = Humanoids[plr]
        if not humanoid or not humanoid.Parent then
            if not UpdateHumanoid(plr) then
                HideAllESP(plr)
                continue
            end
            humanoid = Humanoids[plr]
        end

        -- Получаем позиции (только один раз)
        local rootPos = Camera:WorldToViewportPoint(hrp.Position)
        
        -- Проверка видимости (оптимизировано)
        if rootPos.Z <= 0 or rootPos.Z > ESP.Settings.MaxRenderDistance then
            HideAllESP(plr)
            continue
        end

        -- Проверка на границах экрана
        if rootPos.X < -50 or rootPos.X > viewportSize.X + 50 
           or rootPos.Y < -50 or rootPos.Y > viewportSize.Y + 50 then
            HideAllESP(plr)
            continue
        end

        -- Получаем остальные позиции
        local headPos = Camera:WorldToViewportPoint(head.Position + Vector3new(0, 0.6, 0))
        local legPos = Camera:WorldToViewportPoint(hrp.Position - Vector3new(0, 3.5, 0))

        -- Вычисляем размеры
        local height = math_abs(headPos.Y - legPos.Y)
        
        -- Защита от слишком маленьких размеров
        if height < 10 then
            height = 30 -- Минимальная высота
        end
        
        local width = height * 0.55
        
        -- Получаем здоровье
        local health, maxHealth = GetSafeHealthValues(humanoid)
        
        -- Проверка здоровья
        if health <= 0 or maxHealth <= 0 then
            HideAllESP(plr)
            continue
        end
        
        local healthPercent = math_max(0, math_min(1, health / maxHealth))

        -- Обновляем box
        if ESP.Settings.EspBox and box then
            box.Size = Vector2new(width, height)
            box.Position = Vector2new(rootPos.X - width/2, rootPos.Y - height/2)
            box.Color = ESP.Settings.BoxColor
            box.Thickness = ESP.Settings.BoxThickness
            box.Transparency = ESP.Settings.Transparency
            box.Visible = true
        elseif box then
            box.Visible = false
        end

        -- Обновляем имя
        if ESP.Settings.EspName and nameTag then
            nameTag.Position = Vector2new(rootPos.X, rootPos.Y - height/2 - 20)
            nameTag.Color = ESP.Settings.NameColor
            nameTag.OutlineColor = ESP.Settings.OutlineColor
            nameTag.Visible = true
        elseif nameTag then
            nameTag.Visible = false
        end

        -- Обновляем полоску здоровья
        if ESP.Settings.EspHealthBar and healthBar and healthBar.bg and healthBar.fill then
            local barWidth = ESP.Settings.HealthBarWidth
            local barHeight = height
            local barX = rootPos.X - width/2 - barWidth - 2
            local barY = rootPos.Y - height/2

            -- Проверяем, что позиции в пределах разумного
            if barX > -1000 and barX < viewportSize.X + 1000 
               and barY > -1000 and barY < viewportSize.Y + 1000 then
                
                healthBar.bg.Size = Vector2new(barWidth, barHeight)
                healthBar.bg.Position = Vector2new(barX, barY)
                healthBar.bg.Visible = true

                local fillHeight = barHeight * healthPercent
                fillHeight = math_max(0, math_min(barHeight, fillHeight))

                healthBar.fill.Color = GetHealthColor(healthPercent)
                healthBar.fill.Size = Vector2new(barWidth, fillHeight)
                healthBar.fill.Position = Vector2new(barX, barY + (barHeight - fillHeight))
                healthBar.fill.Visible = true
            else
                healthBar.bg.Visible = false
                healthBar.fill.Visible = false
            end
        elseif healthBar then
            if healthBar.bg then healthBar.bg.Visible = false end
            if healthBar.fill then healthBar.fill.Visible = false end
        end

        -- Обновляем текст здоровья
        if ESP.Settings.EspHealthText and healthText and humanoid then
            local textX = rootPos.X - width/2 - 30
            if textX > -500 and textX < viewportSize.X + 500 then
                healthText.Color = GetHealthColor(healthPercent)
                healthText.OutlineColor = ESP.Settings.OutlineColor
                healthText.Text = string.format("%d/%d", math_floor(health), math_floor(maxHealth))
                healthText.Position = Vector2new(textX, rootPos.Y)
                healthText.Visible = true
            else
                healthText.Visible = false
            end
        elseif healthText then
            healthText.Visible = false
        end
    end
end)

-- Подключаем события
Players.PlayerAdded:Connect(OnPlayerAdded)
Players.PlayerRemoving:Connect(RemoveESP)

-- Обрабатываем уже существующих игроков
for _, plr in Players:GetPlayers() do
    if plr ~= LocalPlayer or ESP.Settings.ShowSelf then
        OnPlayerAdded(plr)
    end
end

print("ESP loaded with automatic settings update!")

return ESP
