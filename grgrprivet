local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- Основная таблица ESP (как в Kiriot)
local ESP = {
    -- Настройки (можно менять извне)
    Enabled = false,
    -- Box
    BoxEnabled = false,
    BoxColor = Color3.fromRGB(255, 0, 0),
    BoxThickness = 1.6,
    -- Name
    NameEnabled = false,
    NameColor = Color3.fromRGB(255, 255, 255),
    NameSize = 16,
    -- Health
    HealthEnabled = false,
    HealthBarWidth = 6,
    HealthTextEnabled = false,
    -- Distance
    DistanceEnabled = false,
    DistanceColor = Color3.fromRGB(255, 255, 255),
    DistanceSize = 14,
    -- Общие
    MaxDistance = 1000,
    ShowEnemies = true,
    ShowTeammates = false,
    OutlineColor = Color3.fromRGB(0, 0, 0),
    
    -- Внутренние таблицы
    Objects = {},  -- объекты ESP
    Connections = {},  -- соединения
}

-- Хранилище для плавности
local LastSizes = {}
local Cache = {
    ViewportSize = Vector2.new(0, 0),
    CameraPos = Vector3.new(0, 0, 0),
}

-- Цвет здоровья
local function GetHealthColor(percent)
    if percent > 0.6 then
        return Color3.fromRGB(0, 255, 0)
    elseif percent > 0.3 then
        return Color3.fromRGB(255, 255, 0)
    elseif percent > 0.1 then
        return Color3.fromRGB(255, 100, 0)
    else
        return Color3.fromRGB(255, 0, 0)
    end
end

-- Интерполяция
local function Lerp(a, b, t)
    return a + (b - a) * t
end

local function LerpVector2(a, b, t)
    if not a then return b end
    if not b then return a end
    return Vector2.new(
        Lerp(a.X, b.X, t),
        Lerp(a.Y, b.Y, t)
    )
end

-- Проверка врага
local function IsEnemy(plr)
    if plr == LocalPlayer then return false end
    local myChar = LocalPlayer.Character
    local theirChar = plr.Character
    if not myChar or not theirChar then return false end
    
    local myTeam = myChar.Parent and myChar.Parent.Name or "Enemy"
    local theirTeam = theirChar.Parent and theirChar.Parent.Name or "Enemy"
    local isEnemy = myTeam ~= theirTeam
    
    return isEnemy and ESP.ShowEnemies or (not isEnemy and ESP.ShowTeammates)
end

-- Получение дистанции
local function GetDistance(pos)
    local dist = (Cache.CameraPos - pos).Magnitude
    return math.floor(dist / 3.28)
end

-- Создание ESP для игрока
local function CreateESP(plr)
    if ESP.Objects[plr] then return end
    
    local objects = {}
    
    -- Box
    objects.Box = Drawing.new("Square")
    objects.Box.Thickness = ESP.BoxThickness
    objects.Box.Filled = false
    objects.Box.Color = ESP.BoxColor
    objects.Box.Transparency = 1
    objects.Box.Visible = false
    
    -- Name
    objects.Name = Drawing.new("Text")
    objects.Name.Text = plr.Name
    objects.Name.Size = ESP.NameSize
    objects.Name.Color = ESP.NameColor
    objects.Name.Center = true
    objects.Name.Outline = true
    objects.Name.OutlineColor = ESP.OutlineColor
    objects.Name.Visible = false
    
    -- Distance
    objects.Distance = Drawing.new("Text")
    objects.Distance.Size = ESP.DistanceSize
    objects.Distance.Color = ESP.DistanceColor
    objects.Distance.Center = true
    objects.Distance.Outline = true
    objects.Distance.OutlineColor = ESP.OutlineColor
    objects.Distance.Visible = false
    
    -- Health Bar (фон)
    objects.HealthBarBg = Drawing.new("Square")
    objects.HealthBarBg.Thickness = 1
    objects.HealthBarBg.Filled = true
    objects.HealthBarBg.Color = Color3.fromRGB(0, 0, 0)
    objects.HealthBarBg.Transparency = 0.7
    objects.HealthBarBg.Visible = false
    
    -- Health Bar (заполнение)
    objects.HealthBarFill = Drawing.new("Square")
    objects.HealthBarFill.Thickness = 1
    objects.HealthBarFill.Filled = true
    objects.HealthBarFill.Color = Color3.fromRGB(0, 255, 0)
    objects.HealthBarFill.Transparency = 0.7
    objects.HealthBarFill.Visible = false
    
    -- Health Text
    objects.HealthText = Drawing.new("Text")
    objects.HealthText.Size = 14
    objects.HealthText.Color = Color3.fromRGB(255, 255, 255)
    objects.HealthText.Center = true
    objects.HealthText.Outline = true
    objects.HealthText.OutlineColor = ESP.OutlineColor
    objects.HealthText.Visible = false
    
    ESP.Objects[plr] = objects
    LastSizes[plr] = nil
end

-- Удаление ESP для игрока
local function RemoveESP(plr)
    if ESP.Objects[plr] then
        for _, obj in pairs(ESP.Objects[plr]) do
            obj:Remove()
        end
        ESP.Objects[plr] = nil
    end
    LastSizes[plr] = nil
end

-- Конвертация 3D в 2D
local function WorldToScreen(pos)
    local vector = Camera:WorldToViewportPoint(pos)
    return vector.X, vector.Y, vector.Z
end

-- Проверка на экране
local function IsOnScreen(x, y, z)
    return z > 0.1 and 
           x >= 0 and x <= Cache.ViewportSize.X and
           y >= 0 and y <= Cache.ViewportSize.Y
end

-- ОСНОВНОЙ ЦИКЛ (читает настройки каждый кадр - как в Kiriot)
RunService.RenderStepped:Connect(function()
    -- Кэшируем часто используемые значения
    Cache.ViewportSize = Camera.ViewportSize
    Cache.CameraPos = Camera.CFrame.Position
    
    -- Проверяем включен ли ESP (читаем каждый кадр)
    if not ESP.Enabled then
        -- Если ESP выключен - прячем все объекты
        for plr, objs in pairs(ESP.Objects) do
            for _, obj in pairs(objs) do
                obj.Visible = false
            end
        end
        return
    end
    
    -- Основной цикл отрисовки
    for plr, objs in pairs(ESP.Objects) do
        local char = plr.Character
        if not char then 
            for _, obj in pairs(objs) do obj.Visible = false end
            continue 
        end
        
        -- Получаем части
        local hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
        local head = char:FindFirstChild("Head")
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        
        if not hrp or not head or not humanoid or humanoid.Health <= 0 then
            for _, obj in pairs(objs) do obj.Visible = false end
            continue
        end
        
        -- Проверка дистанции (читаем каждый кадр)
        local distance = (Cache.CameraPos - hrp.Position).Magnitude
        if distance > ESP.MaxDistance then
            for _, obj in pairs(objs) do obj.Visible = false end
            continue
        end
        
        -- Проверка врага (читаем каждый кадр)
        if not IsEnemy(plr) then
            for _, obj in pairs(objs) do obj.Visible = false end
            continue
        end
        
        -- Получаем позиции
        local headX, headY, headZ = WorldToScreen(head.Position + Vector3.new(0, 0.6, 0))
        local rootX, rootY, rootZ = WorldToScreen(hrp.Position)
        local legX, legY, legZ = WorldToScreen(hrp.Position - Vector3.new(0, 3.5, 0))
        
        -- Проверка видимости
        if not IsOnScreen(rootX, rootY, rootZ) and not IsOnScreen(headX, headY, headZ) then
            for _, obj in pairs(objs) do obj.Visible = false end
            continue
        end
        
        -- Используем доступные координаты
        local finalRootX, finalRootY = rootX, rootY
        local finalHeadY = IsOnScreen(headX, headY, headZ) and headY or (rootY - 50)
        local finalLegY = IsOnScreen(legX, legY, legZ) and legY or (rootY + 50)
        
        -- Вычисляем размеры
        local height = math.abs(finalHeadY - finalLegY)
        local width = height * 0.55
        
        if height < 10 or width < 5 then
            for _, obj in pairs(objs) do obj.Visible = false end
            continue
        end
        
        local health = humanoid.Health
        local maxHealth = humanoid.MaxHealth
        local healthPercent = health / maxHealth
        local healthColor = GetHealthColor(healthPercent)
        
        -- Обновляем Box (с ТЕКУЩИМИ настройками)
        if ESP.BoxEnabled then
            objs.Box.Position = Vector2.new(finalRootX - width/2, finalRootY - height/2)
            
            -- Плавность размера
            if LastSizes[plr] then
                local newSize = Vector2.new(width, height)
                local smoothSize = LerpVector2(LastSizes[plr], newSize, 0.5)
                objs.Box.Size = smoothSize
                LastSizes[plr] = smoothSize
            else
                objs.Box.Size = Vector2.new(width, height)
                LastSizes[plr] = Vector2.new(width, height)
            end
            
            -- Применяем текущие настройки
            objs.Box.Color = ESP.BoxColor
            objs.Box.Thickness = ESP.BoxThickness
            objs.Box.Visible = true
        else
            objs.Box.Visible = false
        end
        
        -- Обновляем Name (с ТЕКУЩИМИ настройками)
        if ESP.NameEnabled then
            objs.Name.Position = Vector2.new(finalRootX, finalRootY - height/2 - 20)
            objs.Name.Color = ESP.NameColor
            objs.Name.OutlineColor = ESP.OutlineColor
            objs.Name.Size = ESP.NameSize  -- обновляем размер
            objs.Name.Visible = true
        else
            objs.Name.Visible = false
        end
        
        -- Обновляем Distance (с ТЕКУЩИМИ настройками)
        if ESP.DistanceEnabled then
            local distMeters = GetDistance(hrp.Position)
            objs.Distance.Text = distMeters .. "m"
            objs.Distance.Position = Vector2.new(finalRootX, finalRootY + height/2 + 20)
            objs.Distance.Color = ESP.DistanceColor
            objs.Distance.OutlineColor = ESP.OutlineColor
            objs.Distance.Size = ESP.DistanceSize  -- обновляем размер
            objs.Distance.Visible = true
        else
            objs.Distance.Visible = false
        end
        
        -- Обновляем Health Bar (с ТЕКУЩИМИ настройками)
        if ESP.HealthEnabled then
            local barWidth = ESP.HealthBarWidth
            local barX = finalRootX - width/2 - barWidth - 2
            local barY = finalRootY - height/2
            
            -- Background
            objs.HealthBarBg.Size = Vector2.new(barWidth, height)
            objs.HealthBarBg.Position = Vector2.new(barX, barY)
            objs.HealthBarBg.Visible = true
            
            -- Fill
            local fillHeight = height * healthPercent
            objs.HealthBarFill.Size = Vector2.new(barWidth, fillHeight)
            objs.HealthBarFill.Position = Vector2.new(barX, barY + (height - fillHeight))
            objs.HealthBarFill.Color = healthColor
            objs.HealthBarFill.Visible = true
        else
            objs.HealthBarBg.Visible = false
            objs.HealthBarFill.Visible = false
        end
        
        -- Обновляем Health Text (с ТЕКУЩИМИ настройками)
        if ESP.HealthTextEnabled then
            objs.HealthText.Color = healthColor
            objs.HealthText.OutlineColor = ESP.OutlineColor
            objs.HealthText.Text = string.format("%d/%d", math.floor(health), math.floor(maxHealth))
            objs.HealthText.Position = Vector2.new(finalRootX - width/2 - 35, finalRootY)
            objs.HealthText.Visible = true
        else
            objs.HealthText.Visible = false
        end
    end
end)

-- Отслеживаем смерть/респавн
local function OnCharacterAdded(plr)
    RemoveESP(plr)
    CreateESP(plr)
end

-- Подключаем события
Players.PlayerAdded:Connect(function(plr)
    CreateESP(plr)
    
    ESP.Connections[plr] = {
        plr.CharacterAdded:Connect(function() OnCharacterAdded(plr) end),
        plr.CharacterRemoving:Connect(function() RemoveESP(plr) end),
    }
end)

Players.PlayerRemoving:Connect(function(plr)
    RemoveESP(plr)
    if ESP.Connections[plr] then
        for _, conn in pairs(ESP.Connections[plr]) do
            conn:Disconnect()
        end
        ESP.Connections[plr] = nil
    end
end)

-- Существующие игроки
for _, plr in Players:GetPlayers() do
    if plr ~= LocalPlayer then
        CreateESP(plr)
        
        ESP.Connections[plr] = {
            plr.CharacterAdded:Connect(function() OnCharacterAdded(plr) end),
            plr.CharacterRemoving:Connect(function() RemoveESP(plr) end),
        }
    end
end

print("ESP loaded - можно менять настройки через ESP.Enabled, ESP.BoxEnabled и т.д.")

-- ВОЗВРАЩАЕМ ТАБЛИЦУ (как в Kiriot)
return ESP
