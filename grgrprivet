--[[
    OPTIMIZED ESP - меньше лагов
]]

local ESP = {}
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- Настройки ESP
ESP.Settings = {
    Enabled = true,
    EspBox = true,
    EspName = true,
    EspHealthBar = true,
    EspHealthText = true,
    BoxColor = Color3.fromRGB(255, 0, 0),
    NameColor = Color3.fromRGB(255, 255, 255),
    HealthBarWidth = 6,
    OutlineColor = Color3.fromRGB(0, 0, 0),
    Transparency = 1,
    ShowTeammates = false,
    ShowEnemies = true,
    ShowSelf = false,
    BoxThickness = 1.6,
    MaxRenderDistance = 1000,
    UpdateRate = 2, -- Обновлять позиции каждый 2-й кадр
}

-- Внутренние переменные
local ESPObjects = {}
local PlayerCache = {}
local FrameCounter = 0
local ViewportSize = Camera.ViewportSize

-- Оптимизированная проверка врага (кеширование)
local function IsEnemy(plr)
    if plr == LocalPlayer then 
        return ESP.Settings.ShowSelf
    end

    -- Используем кеш, если он еще свежий (меньше 1 секунды)
    local cached = PlayerCache[plr]
    if cached and cached.team and tick() - cached.time < 1 then
        return cached.isEnemy
    end

    local myChar = LocalPlayer.Character
    local theirChar = plr.Character
    if not myChar or not theirChar then 
        return false 
    end

    -- Быстрое определение команды без pcall
    local myTeam = "Enemy"
    local theirTeam = "Enemy"
    
    if myChar.Parent and myChar.Parent:IsA("Model") then
        myTeam = myChar.Parent.Name
    end
    
    if theirChar.Parent and theirChar.Parent:IsA("Model") then
        theirTeam = theirChar.Parent.Name
    end

    local result = myTeam ~= theirTeam
    
    -- Сохраняем в кеш
    PlayerCache[plr] = {
        team = theirTeam,
        isEnemy = result,
        time = tick()
    }
    
    return result
end

-- Создание ESP объектов (один раз при появлении)
local function CreateESPObjects(plr)
    if ESPObjects[plr] then return end
    
    ESPObjects[plr] = {
        box = Drawing.new("Square"),
        name = Drawing.new("Text"),
        healthBarBg = Drawing.new("Square"),
        healthBarFill = Drawing.new("Square"),
        healthText = Drawing.new("Text"),
        humanoid = nil,
        lastUpdate = 0,
        visible = false
    }
    
    local obj = ESPObjects[plr]
    
    -- Настройка box
    obj.box.Thickness = ESP.Settings.BoxThickness
    obj.box.Filled = false
    obj.box.Color = ESP.Settings.BoxColor
    obj.box.Transparency = ESP.Settings.Transparency
    obj.box.Visible = false
    
    -- Настройка name
    obj.name.Size = 16
    obj.name.Color = ESP.Settings.NameColor
    obj.name.Center = true
    obj.name.Outline = true
    obj.name.OutlineColor = ESP.Settings.OutlineColor
    obj.name.Visible = false
    
    -- Настройка health bar
    obj.healthBarBg.Thickness = 1
    obj.healthBarBg.Filled = true
    obj.healthBarBg.Color = Color3.fromRGB(0, 0, 0)
    obj.healthBarBg.Transparency = 0.7
    obj.healthBarBg.Visible = false
    
    obj.healthBarFill.Thickness = 1
    obj.healthBarFill.Filled = true
    obj.healthBarFill.Color = Color3.fromRGB(0, 255, 0)
    obj.healthBarFill.Transparency = 0.7
    obj.healthBarFill.Visible = false
    
    -- Настройка health text
    obj.healthText.Size = 14
    obj.healthText.Color = Color3.fromRGB(255, 255, 255)
    obj.healthText.Center = true
    obj.healthText.Outline = true
    obj.healthText.OutlineColor = ESP.Settings.OutlineColor
    obj.healthText.Visible = false
    
    return obj
end

-- Быстрое получение здоровья
local function GetHealthQuick(humanoid)
    if not humanoid then return 0, 100 end
    
    local success, health, maxHealth = pcall(function()
        return humanoid.Health, humanoid.MaxHealth
    end)
    
    if success then
        return math.max(0, health), math.max(1, maxHealth)
    end
    return 0, 100
end

-- Быстрое получение цвета здоровья
local function GetHealthColorQuick(percent)
    if percent > 0.6 then return Color3.fromRGB(0, 255, 0) end
    if percent > 0.3 then return Color3.fromRGB(255, 255, 0) end
    if percent > 0.1 then return Color3.fromRGB(255, 100, 0) end
    return Color3.fromRGB(255, 0, 0)
end

-- Основной цикл с оптимизацией
RunService.RenderStepped:Connect(function()
    if not ESP.Settings.Enabled then return end
    
    FrameCounter = FrameCounter + 1
    local skipFrame = FrameCounter % ESP.Settings.UpdateRate ~= 0
    ViewportSize = Camera.ViewportSize
    
    for plr, obj in pairs(ESPObjects) do
        if plr == LocalPlayer then continue end
        
        local char = plr.Character
        if not char or not char.Parent then
            if obj.visible then
                obj.box.Visible = false
                obj.name.Visible = false
                obj.healthBarBg.Visible = false
                obj.healthBarFill.Visible = false
                obj.healthText.Visible = false
                obj.visible = false
            end
            continue
        end
        
        -- Проверка на врага (с кешем)
        if not IsEnemy(plr) then
            if obj.visible then
                obj.box.Visible = false
                obj.name.Visible = false
                obj.healthBarBg.Visible = false
                obj.healthBarFill.Visible = false
                obj.healthText.Visible = false
                obj.visible = false
            end
            continue
        end
        
        -- Получаем Humanoid (с кешем)
        local humanoid = obj.humanoid
        if not humanoid or not humanoid.Parent then
            humanoid = char:FindFirstChildOfClass("Humanoid")
            if not humanoid or humanoid.Health <= 0 then
                if obj.visible then
                    obj.box.Visible = false
                    obj.name.Visible = false
                    obj.healthBarBg.Visible = false
                    obj.healthBarFill.Visible = false
                    obj.healthText.Visible = false
                    obj.visible = false
                end
                continue
            end
            obj.humanoid = humanoid
        end
        
        -- Получаем части (кешируем если возможно)
        local hrp = obj.hrp
        local head = obj.head
        
        if skipFrame then
            -- Используем кешированные части для пропущенных кадров
            hrp = obj.hrp
            head = obj.head
        else
            -- Обновляем кеш частей
            hrp = char:FindFirstChild("HumanoidRootPart") or 
                  char:FindFirstChild("Torso") or 
                  char:FindFirstChild("UpperTorso")
            head = char:FindFirstChild("Head")
            
            if hrp then obj.hrp = hrp end
            if head then obj.head = head end
        end
        
        if not hrp or not head then
            if obj.visible then
                obj.box.Visible = false
                obj.name.Visible = false
                obj.healthBarBg.Visible = false
                obj.healthBarFill.Visible = false
                obj.healthText.Visible = false
                obj.visible = false
            end
            continue
        end
        
        -- Быстрая проверка дистанции
        local distance = (Camera.CFrame.Position - hrp.Position).Magnitude
        if distance > ESP.Settings.MaxRenderDistance then
            if obj.visible then
                obj.box.Visible = false
                obj.name.Visible = false
                obj.healthBarBg.Visible = false
                obj.healthBarFill.Visible = false
                obj.healthText.Visible = false
                obj.visible = false
            end
            continue
        end
        
        -- Конвертация в экранные координаты (только каждый 2-й кадр)
        if not skipFrame or not obj.lastScreenPos then
            local success, rootPos = pcall(function()
                return Camera:WorldToViewportPoint(hrp.Position)
            end)
            
            if not success or rootPos.Z <= 0.1 then
                if obj.visible then
                    obj.box.Visible = false
                    obj.name.Visible = false
                    obj.healthBarBg.Visible = false
                    obj.healthBarFill.Visible = false
                    obj.healthText.Visible = false
                    obj.visible = false
                end
                continue
            end
            
            -- Получаем позицию головы
            local headPos
            pcall(function()
                headPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
            end)
            
            if not headPos then
                headPos = Vector3.new(rootPos.X, rootPos.Y - 50, rootPos.Z)
            end
            
            -- Сохраняем позиции
            obj.lastScreenPos = {
                root = Vector2.new(rootPos.X, rootPos.Y),
                head = Vector2.new(headPos.X, headPos.Y),
                z = rootPos.Z
            }
            
            -- Вычисляем размеры
            local height = math.abs(headPos.Y - (rootPos.Y + 50))
            if height < 10 then height = 50 end
            obj.lastHeight = height
            obj.lastWidth = height * 0.55
        end
        
        -- Используем сохраненные позиции
        local screenPos = obj.lastScreenPos
        local height = obj.lastHeight
        local width = obj.lastWidth
        
        -- Получаем здоровье
        local health, maxHealth = GetHealthQuick(humanoid)
        local healthPercent = health / maxHealth
        
        -- Обновляем визуальные элементы
        local anyVisible = false
        
        -- Box
        if ESP.Settings.EspBox then
            obj.box.Size = Vector2.new(width, height)
            obj.box.Position = Vector2.new(screenPos.root.X - width/2, screenPos.root.Y - height/2)
            obj.box.Color = ESP.Settings.BoxColor
            obj.box.Thickness = ESP.Settings.BoxThickness
            obj.box.Transparency = ESP.Settings.Transparency
            if not obj.box.Visible then obj.box.Visible = true end
            anyVisible = true
        end
        
        -- Name
        if ESP.Settings.EspName then
            obj.name.Position = Vector2.new(screenPos.root.X, screenPos.root.Y - height/2 - 20)
            obj.name.Color = ESP.Settings.NameColor
            obj.name.OutlineColor = ESP.Settings.OutlineColor
            obj.name.Text = plr.Name
            if not obj.name.Visible then obj.name.Visible = true end
            anyVisible = true
        end
        
        -- Health Bar
        if ESP.Settings.EspHealthBar then
            local barWidth = ESP.Settings.HealthBarWidth
            local barX = screenPos.root.X - width/2 - barWidth - 2
            local barY = screenPos.root.Y - height/2
            
            obj.healthBarBg.Size = Vector2.new(barWidth, height)
            obj.healthBarBg.Position = Vector2.new(barX, barY)
            if not obj.healthBarBg.Visible then obj.healthBarBg.Visible = true end
            
            local fillHeight = height * healthPercent
            obj.healthBarFill.Color = GetHealthColorQuick(healthPercent)
            obj.healthBarFill.Size = Vector2.new(barWidth, fillHeight)
            obj.healthBarFill.Position = Vector2.new(barX, barY + (height - fillHeight))
            if not obj.healthBarFill.Visible then obj.healthBarFill.Visible = true end
            
            anyVisible = true
        end
        
        -- Health Text
        if ESP.Settings.EspHealthText then
            obj.healthText.Color = GetHealthColorQuick(healthPercent)
            obj.healthText.OutlineColor = ESP.Settings.OutlineColor
            obj.healthText.Text = string.format("%d/%d", math.floor(health), math.floor(maxHealth))
            obj.healthText.Position = Vector2.new(screenPos.root.X - width/2 - 35, screenPos.root.Y)
            if not obj.healthText.Visible then obj.healthText.Visible = true end
            anyVisible = true
        end
        
        obj.visible = anyVisible
    end
end)

-- Обработка появления игроков
local function OnPlayerAdded(plr)
    if plr == LocalPlayer then return end
    
    -- Создаем объекты сразу
    CreateESPObjects(plr)
    
    -- Отслеживаем появление персонажа
    plr.CharacterAdded:Connect(function(char)
        local obj = ESPObjects[plr]
        if obj then
            obj.humanoid = char:FindFirstChildOfClass("Humanoid")
            obj.hrp = nil
            obj.head = nil
        end
    end)
    
    -- Если персонаж уже есть
    if plr.Character then
        local obj = ESPObjects[plr]
        if obj then
            obj.humanoid = plr.Character:FindFirstChildOfClass("Humanoid")
        end
    end
end

-- Обработка удаления игроков
local function OnPlayerRemoving(plr)
    local obj = ESPObjects[plr]
    if obj then
        obj.box:Remove()
        obj.name:Remove()
        obj.healthBarBg:Remove()
        obj.healthBarFill:Remove()
        obj.healthText:Remove()
        ESPObjects[plr] = nil
    end
    PlayerCache[plr] = nil
end

-- Подключаем события
Players.PlayerAdded:Connect(OnPlayerAdded)
Players.PlayerRemoving:Connect(OnPlayerRemoving)

-- Обрабатываем существующих игроков
for _, plr in Players:GetPlayers() do
    OnPlayerAdded(plr)
end

return ESP
