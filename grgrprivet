local ESP = {}
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- Настройки ESP
ESP.Settings = {
    Enabled = true,
    EspBox = true,
    EspName = true,
    EspHealthBar = true,
    EspHealthText = true,
    BoxColor = Color3.fromRGB(255, 0, 0),
    NameColor = Color3.fromRGB(255, 255, 255),
    HealthBarWidth = 6,
    OutlineColor = Color3.fromRGB(0, 0, 0),
    Transparency = 1,
    ShowTeammates = false,
    ShowEnemies = true,
    ShowSelf = false,
    BoxThickness = 1.6,
    MaxRenderDistance = 1000,
}

-- Внутренние переменные
ESP.Objects = {} -- Все объекты ESP
ESP.Overrides = {} -- Для кастомных функций (как в чужом коде)

-- Вспомогательные функции (аналог Framework)
local function WorldToScreen(position)
    local success, result = pcall(function()
        return Camera:WorldToViewportPoint(position)
    end)
    
    if success and result then
        return {
            X = result.X,
            Y = result.Y,
            Z = result.Z,
            OnScreen = result.Z > 0.1
        }
    end
    return {X = -1, Y = -1, Z = -1, OnScreen = false}
end

local function IsOnScreen(screenPos)
    return screenPos.OnScreen and 
           screenPos.X >= 0 and screenPos.X <= Camera.ViewportSize.X and
           screenPos.Y >= 0 and screenPos.Y <= Camera.ViewportSize.Y
end

local function GetHealthColor(percent)
    percent = math.max(0, math.min(1, percent))
    if percent > 0.6 then
        return Color3.fromRGB(0, 255, 0)
    elseif percent > 0.3 then
        return Color3.fromRGB(255, 255, 0)
    elseif percent > 0.1 then
        return Color3.fromRGB(255, 100, 0)
    else
        return Color3.fromRGB(255, 0, 0)
    end
end

-- Функции для получения данных (с поддержкой Overrides)
function ESP:GetCharacter(plr)
    if self.Overrides.GetCharacter then
        return self.Overrides.GetCharacter(plr)
    end
    return plr.Character
end

function ESP:GetHumanoid(character)
    if not character then return nil end
    if self.Overrides.GetHumanoid then
        return self.Overrides.GetHumanoid(character)
    end
    return character:FindFirstChildOfClass("Humanoid")
end

function ESP:GetTeam(plr)
    if self.Overrides.GetTeam then
        return self.Overrides.GetTeam(plr)
    end
    local char = self:GetCharacter(plr)
    if char and char.Parent then
        return char.Parent.Name
    end
    return "Enemy"
end

function ESP:IsEnemy(plr)
    if plr == LocalPlayer then 
        return ESP.Settings.ShowSelf
    end
    
    if self.Overrides.IsEnemy then
        return self.Overrides.IsEnemy(plr)
    end
    
    local myTeam = self:GetTeam(LocalPlayer)
    local theirTeam = self:GetTeam(plr)
    local isEnemy = myTeam ~= theirTeam
    
    if isEnemy then
        return ESP.Settings.ShowEnemies
    else
        return ESP.Settings.ShowTeammates
    end
end

-- Метатаблица для игроков (как в чужом коде)
local PlayerMetatable = {}
PlayerMetatable.__index = PlayerMetatable

function PlayerMetatable:Destroy()
    for name, component in pairs(self.Components) do
        if component then
            pcall(function() component:Remove() end)
        end
    end
    self.Components = {}
    ESP.Objects[self.Player] = nil
end

function PlayerMetatable:CreateComponents()
    local c = {}
    
    -- Box
    c.Box = Drawing.new("Square")
    c.Box.Thickness = ESP.Settings.BoxThickness
    c.Box.Filled = false
    c.Box.Visible = false
    
    -- Name
    c.Name = Drawing.new("Text")
    c.Name.Text = self.Player.Name
    c.Name.Size = 16
    c.Name.Center = true
    c.Name.Outline = true
    c.Name.Visible = false
    
    -- Health Bar Background
    c.HealthBarBg = Drawing.new("Square")
    c.HealthBarBg.Thickness = 1
    c.HealthBarBg.Filled = true
    c.HealthBarBg.Color = Color3.fromRGB(0, 0, 0)
    c.HealthBarBg.Transparency = 0.7
    c.HealthBarBg.Visible = false
    
    -- Health Bar Fill
    c.HealthBarFill = Drawing.new("Square")
    c.HealthBarFill.Thickness = 1
    c.HealthBarFill.Filled = true
    c.HealthBarFill.Visible = false
    
    -- Health Text
    c.HealthText = Drawing.new("Text")
    c.HealthText.Size = 14
    c.HealthText.Center = true
    c.HealthText.Outline = true
    c.HealthText.Visible = false
    
    self.Components = c
end

function PlayerMetatable:Update()
    local c = self.Components
    if not c then return end
    
    -- Проверка настроек
    if not ESP.Settings.Enabled then
        c.Box.Visible = false
        c.Name.Visible = false
        c.HealthBarBg.Visible = false
        c.HealthBarFill.Visible = false
        c.HealthText.Visible = false
        return
    end
    
    -- Получаем персонажа
    local char = ESP:GetCharacter(self.Player)
    if not char or not char.Parent then
        self:Destroy()
        return
    end
    
    -- Получаем части тела
    local hrp = char:FindFirstChild("HumanoidRootPart") or 
                char:FindFirstChild("Torso") or 
                char:FindFirstChild("UpperTorso")
    local head = char:FindFirstChild("Head")
    
    if not hrp or not head then
        c.Box.Visible = false
        c.Name.Visible = false
        c.HealthBarBg.Visible = false
        c.HealthBarFill.Visible = false
        c.HealthText.Visible = false
        return
    end
    
    -- Проверка на врага
    if not ESP:IsEnemy(self.Player) then
        c.Box.Visible = false
        c.Name.Visible = false
        c.HealthBarBg.Visible = false
        c.HealthBarFill.Visible = false
        c.HealthText.Visible = false
        return
    end
    
    -- Получаем Humanoid
    local humanoid = ESP:GetHumanoid(char)
    if not humanoid or humanoid.Health <= 0 then
        c.Box.Visible = false
        c.Name.Visible = false
        c.HealthBarBg.Visible = false
        c.HealthBarFill.Visible = false
        c.HealthText.Visible = false
        return
    end
    
    -- Получаем позиции на экране
    local rootPos = WorldToScreen(hrp.Position)
    local headPos = WorldToScreen(head.Position + Vector3.new(0, 0.5, 0))
    local legPos = WorldToScreen(hrp.Position - Vector3.new(0, 3, 0))
    
    -- Проверяем видимость
    local rootVisible = IsOnScreen(rootPos)
    local headVisible = IsOnScreen(headPos)
    local legVisible = IsOnScreen(legPos)
    
    if not rootVisible and not headVisible and not legVisible then
        c.Box.Visible = false
        c.Name.Visible = false
        c.HealthBarBg.Visible = false
        c.HealthBarFill.Visible = false
        c.HealthText.Visible = false
        return
    end
    
    -- Проверка дистанции
    local distance = (Camera.CFrame.Position - hrp.Position).Magnitude
    if distance > ESP.Settings.MaxRenderDistance then
        c.Box.Visible = false
        c.Name.Visible = false
        c.HealthBarBg.Visible = false
        c.HealthBarFill.Visible = false
        c.HealthText.Visible = false
        return
    end
    
    -- Используем доступные координаты
    local finalRoot = rootVisible and rootPos or (headVisible and headPos or legPos)
    local finalHead = headVisible and headPos or (rootVisible and rootPos or legPos)
    local finalLeg = legVisible and legPos or (rootVisible and rootPos or headPos)
    
    -- Корректируем Y координаты
    if not headVisible and rootVisible then
        finalHead.Y = finalRoot.Y - 50
    end
    if not legVisible and rootVisible then
        finalLeg.Y = finalRoot.Y + 50
    end
    
    -- Вычисляем размеры
    local height = math.abs(finalHead.Y - finalLeg.Y)
    local width = height * 0.55
    
    if height < 10 or width < 5 then
        c.Box.Visible = false
        c.Name.Visible = false
        c.HealthBarBg.Visible = false
        c.HealthBarFill.Visible = false
        c.HealthText.Visible = false
        return
    end
    
    local health = humanoid.Health
    local maxHealth = humanoid.MaxHealth
    local healthPercent = health / maxHealth
    local healthColor = GetHealthColor(healthPercent)
    
    -- Обновляем Box
    if ESP.Settings.EspBox then
        c.Box.Size = Vector2.new(width, height)
        c.Box.Position = Vector2.new(finalRoot.X - width/2, finalRoot.Y - height/2)
        c.Box.Color = ESP.Settings.BoxColor
        c.Box.Thickness = ESP.Settings.BoxThickness
        c.Box.Transparency = ESP.Settings.Transparency
        c.Box.Visible = true
    else
        c.Box.Visible = false
    end
    
    -- Обновляем Name
    if ESP.Settings.EspName then
        c.Name.Position = Vector2.new(finalRoot.X, finalRoot.Y - height/2 - 20)
        c.Name.Color = ESP.Settings.NameColor
        c.Name.OutlineColor = ESP.Settings.OutlineColor
        c.Name.Visible = true
    else
        c.Name.Visible = false
    end
    
    -- Обновляем HealthBar
    if ESP.Settings.EspHealthBar then
        local barWidth = ESP.Settings.HealthBarWidth
        local barX = finalRoot.X - width/2 - barWidth - 2
        local barY = finalRoot.Y - height/2
        
        -- Background
        c.HealthBarBg.Size = Vector2.new(barWidth, height)
        c.HealthBarBg.Position = Vector2.new(barX, barY)
        c.HealthBarBg.Visible = true
        
        -- Fill
        local fillHeight = height * healthPercent
        c.HealthBarFill.Size = Vector2.new(barWidth, fillHeight)
        c.HealthBarFill.Position = Vector2.new(barX, barY + (height - fillHeight))
        c.HealthBarFill.Color = healthColor
        c.HealthBarFill.Visible = true
    else
        c.HealthBarBg.Visible = false
        c.HealthBarFill.Visible = false
    end
    
    -- Обновляем HealthText
    if ESP.Settings.EspHealthText then
        c.HealthText.Color = healthColor
        c.HealthText.OutlineColor = ESP.Settings.OutlineColor
        c.HealthText.Text = string.format("%d/%d", math.floor(health), math.floor(maxHealth))
        c.HealthText.Position = Vector2.new(finalRoot.X - width/2 - 35, finalRoot.Y)
        c.HealthText.Visible = true
    else
        c.HealthText.Visible = false
    end
end

-- Функция создания ESP для игрока
function ESP:AddPlayer(plr)
    if plr == LocalPlayer then return end
    if self.Objects[plr] then 
        self.Objects[plr]:Destroy()
    end
    
    local obj = setmetatable({
        Player = plr,
        Components = {}
    }, PlayerMetatable)
    
    obj:CreateComponents()
    self.Objects[plr] = obj
    
    -- Отслеживаем死亡 и респавн
    local function onCharacterAdded(char)
        -- Пересоздаем компоненты при респавне
        obj:Destroy()
        obj:CreateComponents()
    end
    
    local function onCharacterRemoving()
        obj:Destroy()
    end
    
    -- Очищаем старые соединения
    if obj.Connections then
        for _, conn in pairs(obj.Connections) do
            conn:Disconnect()
        end
    end
    
    obj.Connections = {
        plr.CharacterAdded:Connect(onCharacterAdded),
        plr.CharacterRemoving:Connect(onCharacterRemoving)
    }
    
    if plr.Character then
        onCharacterAdded(plr.Character)
    end
end

-- Обработка добавления игрока
Players.PlayerAdded:Connect(function(plr)
    ESP:AddPlayer(plr)
end)

Players.PlayerRemoving:Connect(function(plr)
    if ESP.Objects[plr] then
        ESP.Objects[plr]:Destroy()
    end
end)

-- Добавляем существующих игроков
for _, plr in Players:GetPlayers() do
    if plr ~= LocalPlayer then
        ESP:AddPlayer(plr)
    end
end

-- Оптимизированный цикл обновления (как в чужом коде)
local lastUpdate = 0
local UPDATE_RATE = 1/30 -- 30 FPS

RunService.Heartbeat:Connect(function()
    local currentTime = tick()
    if currentTime - lastUpdate < UPDATE_RATE then
        return
    end
    lastUpdate = currentTime
    
    -- Обновляем всех игроков
    for _, obj in pairs(ESP.Objects) do
        obj:Update()
    end
end)

print("ESP loaded with optimized architecture")
print("Current CameraMode:", LocalPlayer and LocalPlayer.CameraMode)

return ESP
