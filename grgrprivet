local ESP = {}
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- Настройки ESP
ESP.Settings = {
    Enabled = true,
    EspBox = true,
    EspName = true,
    EspHealthBar = true,
    EspHealthText = true,
    BoxColor = Color3.fromRGB(255, 0, 0),
    NameColor = Color3.fromRGB(255, 255, 255),
    HealthBarWidth = 6,
    OutlineColor = Color3.fromRGB(0, 0, 0),
    Transparency = 1,
    ShowTeammates = false,
    ShowEnemies = true,
    ShowSelf = false,
    BoxThickness = 1.6,
    MaxRenderDistance = 1000,
}

-- Внутренние переменные
local Boxes = {}
local Names = {}
local HealthBars = {}
local HealthTexts = {}
local Humanoids = {}
local Connections = {}
local PlayerData = {}
local HasCharacter = {} -- Флаг наличия персонажа

-- Проверяем режим камеры
local function IsLockFirstPerson()
    return LocalPlayer and LocalPlayer.CameraMode == Enum.CameraMode.LockFirstPerson
end

-- Функция для проверки, враг ли игрок
local function IsEnemy(plr)
    if plr == LocalPlayer then 
        return ESP.Settings.ShowSelf
    end

    local myChar = LocalPlayer.Character
    local theirChar = plr.Character
    if not myChar or not theirChar then return false end

    local myTeam = "Enemy"
    local theirTeam = "Enemy"
    
    pcall(function()
        if myChar.Parent then
            myTeam = myChar.Parent.Name
        end
    end)
    
    pcall(function()
        if theirChar.Parent then
            theirTeam = theirChar.Parent.Name
        end
    end)

    return myTeam ~= theirTeam
end

-- Функция для получения Humanoid
local function GetHumanoid(character)
    if not character then return nil end
    return character:FindFirstChildOfClass("Humanoid")
end

-- Очистка данных игрока
local function ClearPlayerData(plr)
    Humanoids[plr] = nil
    PlayerData[plr] = nil
end

-- Очистка соединений
local function ClearConnections(plr)
    if Connections[plr] then
        for _, conn in pairs(Connections[plr]) do
            pcall(function() conn:Disconnect() end)
        end
        Connections[plr] = nil
    end
end

-- Удаление ESP для игрока
local function DestroyESP(plr)
    local function safeDestroy(obj)
        if obj then
            pcall(function() 
                obj:Remove()
            end)
        end
    end

    safeDestroy(Boxes[plr])
    Boxes[plr] = nil
    
    safeDestroy(Names[plr])
    Names[plr] = nil
    
    if HealthBars[plr] then
        safeDestroy(HealthBars[plr].bg)
        safeDestroy(HealthBars[plr].fill)
        HealthBars[plr] = nil
    end
    
    safeDestroy(HealthTexts[plr])
    HealthTexts[plr] = nil

    ClearPlayerData(plr)
    ClearConnections(plr)
    HasCharacter[plr] = false
end

-- Создание ESP для игрока
local function CreateESP(plr)
    if Boxes[plr] then return end

    local box = Drawing.new("Square")
    box.Thickness = ESP.Settings.BoxThickness
    box.Filled = false
    box.Color = ESP.Settings.BoxColor
    box.Transparency = ESP.Settings.Transparency
    box.Visible = false
    Boxes[plr] = box

    local nameTag = Drawing.new("Text")
    nameTag.Text = plr.Name
    nameTag.Size = 16
    nameTag.Color = ESP.Settings.NameColor
    nameTag.Center = true
    nameTag.Outline = true
    nameTag.OutlineColor = ESP.Settings.OutlineColor
    nameTag.Visible = false
    Names[plr] = nameTag

    local healthBarBg = Drawing.new("Square")
    healthBarBg.Thickness = 1
    healthBarBg.Filled = true
    healthBarBg.Color = Color3.fromRGB(0, 0, 0)
    healthBarBg.Transparency = 0.7
    healthBarBg.Visible = false
    
    local healthBarFill = Drawing.new("Square")
    healthBarFill.Thickness = 1
    healthBarFill.Filled = true
    healthBarFill.Color = Color3.fromRGB(0, 255, 0)
    healthBarFill.Transparency = 0.7
    healthBarFill.Visible = false
    
    HealthBars[plr] = {bg = healthBarBg, fill = healthBarFill}

    local healthText = Drawing.new("Text")
    healthText.Size = 14
    healthText.Color = Color3.fromRGB(255, 255, 255)
    healthText.Center = true
    healthText.Outline = true
    healthText.OutlineColor = ESP.Settings.OutlineColor
    healthText.Visible = false
    HealthTexts[plr] = healthText
    
    HasCharacter[plr] = true
end

-- Получение цвета здоровья
local function GetHealthColor(percent)
    percent = math.max(0, math.min(1, percent))
    
    if percent > 0.6 then
        return Color3.fromRGB(0, 255, 0)
    elseif percent > 0.3 then
        return Color3.fromRGB(255, 255, 0)
    elseif percent > 0.1 then
        return Color3.fromRGB(255, 100, 0)
    else
        return Color3.fromRGB(255, 0, 0)
    end
end

-- Безопасное получение значений здоровья
local function GetSafeHealthValues(humanoid)
    if not humanoid then
        return 0, 100
    end

    local maxHealth = 100
    local health = 0
    
    pcall(function()
        maxHealth = humanoid.MaxHealth
        if maxHealth <= 0 then maxHealth = 100 end
    end)
    
    pcall(function()
        health = humanoid.Health
        if health < 0 then health = 0 end
    end)

    return health, maxHealth
end

-- Функция для конвертации 3D в 2D
local function WorldToScreen(position)
    local success, result = pcall(function()
        return Camera:WorldToViewportPoint(position)
    end)
    
    if success and result then
        if typeof(result) == "Vector3" then
            return {
                X = result.X,
                Y = result.Y,
                Z = result.Z,
                Visible = result.Z > 0.1
            }
        elseif type(result) == "table" then
            return {
                X = result.X or result[1] or 0,
                Y = result.Y or result[2] or 0,
                Z = result.Z or result[3] or 1,
                Visible = (result.Z or result[3] or 1) > 0.1
            }
        end
    end
    
    success, result = pcall(function()
        return Camera:WorldToScreenPoint(position)
    end)
    
    if success and result then
        return {
            X = result.X,
            Y = result.Y,
            Z = result.Z,
            Visible = result.Z > 0.1
        }
    end
    
    return {
        X = Camera.ViewportSize.X / 2,
        Y = Camera.ViewportSize.Y / 2,
        Z = -1,
        Visible = false
    }
end

-- Проверка видимости на экране
local function IsOnScreen(screenPos)
    if not screenPos.Visible or screenPos.Z <= 0.1 then
        return false
    end
    
    if screenPos.X < 0 or screenPos.X > Camera.ViewportSize.X then
        return false
    end
    
    if screenPos.Y < 0 or screenPos.Y > Camera.ViewportSize.Y then
        return false
    end
    
    return true
end

-- Отслеживание смерти
local function TrackDeath(plr, humanoid)
    if not humanoid then return end

    if not Connections[plr] then
        Connections[plr] = {}
    end

    local healthChangedConn = humanoid:GetPropertyChangedSignal("Health"):Connect(function()
        PlayerData[plr] = PlayerData[plr] or {}
        PlayerData[plr].healthChanged = true
    end)
    table.insert(Connections[plr], healthChangedConn)

    local diedConn = humanoid.Died:Connect(function()
        ClearPlayerData(plr)
        -- Не удаляем ESP при смерти, просто прячем
        if Boxes[plr] then
            Boxes[plr].Visible = false
            Names[plr].Visible = false
            if HealthBars[plr] then
                HealthBars[plr].bg.Visible = false
                HealthBars[plr].fill.Visible = false
            end
            HealthTexts[plr].Visible = false
        end
        HasCharacter[plr] = false
    end)
    table.insert(Connections[plr], diedConn)
end

-- Обработка добавления персонажа
local function OnCharacterAdded(plr, char)
    -- Создаем ESP если его еще нет
    if not Boxes[plr] then
        CreateESP(plr)
    end
    
    ClearPlayerData(plr)
    ClearConnections(plr)

    Connections[plr] = {}

    task.wait(0.3)

    UpdateHumanoid(plr)

    local humanoid = Humanoids[plr]
    if humanoid then
        TrackDeath(plr, humanoid)
    end

    local childAddedConn = char.ChildAdded:Connect(function(child)
        if child:IsA("Humanoid") then
            UpdateHumanoid(plr)
            TrackDeath(plr, child)
        end
    end)
    table.insert(Connections[plr], childAddedConn)

    -- ВАЖНО: Когда персонаж удаляется - УДАЛЯЕМ ESP
    local charRemovedConn = char.AncestryChanged:Connect(function()
        if not char.Parent then
            -- Персонаж удален - удаляем ESP
            DestroyESP(plr)
        end
    end)
    table.insert(Connections[plr], charRemovedConn)
    
    HasCharacter[plr] = true
end

-- Обновление Humanoid
local function UpdateHumanoid(plr)
    local char = plr.Character
    if char then
        local newHumanoid = GetHumanoid(char)
        if newHumanoid and newHumanoid.Health > 0 then
            Humanoids[plr] = newHumanoid
            PlayerData[plr] = {
                lastUpdate = tick(),
                valid = true
            }
            return true
        end
    end

    ClearPlayerData(plr)
    return false
end

-- Обработка добавления игрока
local function OnPlayerAdded(plr)
    if plr == LocalPlayer then
        return
    end

    -- Создаем ESP сразу
    CreateESP(plr)

    local charAddedConn = plr.CharacterAdded:Connect(function(char)
        OnCharacterAdded(plr, char)
    end)

    if not Connections[plr] then
        Connections[plr] = {}
    end
    table.insert(Connections[plr], charAddedConn)

    if plr.Character then
        OnCharacterAdded(plr, plr.Character)
    end
end

-- Отслеживаем изменения в настройках
local SettingsMetatable = {
    __newindex = function(t, key, value)
        rawset(t, key, value)

        if key == "BoxColor" or key == "BoxThickness" then
            for plr, box in pairs(Boxes) do
                if box then
                    box.Color = ESP.Settings.BoxColor
                    box.Thickness = ESP.Settings.BoxThickness
                end
            end
        elseif key == "NameColor" or key == "OutlineColor" then
            for plr, nameTag in pairs(Names) do
                if nameTag then
                    nameTag.Color = ESP.Settings.NameColor
                    nameTag.OutlineColor = ESP.Settings.OutlineColor
                end
            end
            for plr, healthText in pairs(HealthTexts) do
                if healthText then
                    healthText.OutlineColor = ESP.Settings.OutlineColor
                end
            end
        end
    end
}

setmetatable(ESP.Settings, SettingsMetatable)

-- Основной цикл
RunService.RenderStepped:Connect(function()
    for plr, box in pairs(Boxes) do
        if plr == LocalPlayer then
            continue
        end

        if not ESP.Settings.Enabled then
            box.Visible = false
            if Names[plr] then Names[plr].Visible = false end
            if HealthBars[plr] then
                HealthBars[plr].bg.Visible = false
                HealthBars[plr].fill.Visible = false
            end
            if HealthTexts[plr] then HealthTexts[plr].Visible = false end
            continue
        end

        -- Проверяем есть ли персонаж
        if not HasCharacter[plr] then
            box.Visible = false
            if Names[plr] then Names[plr].Visible = false end
            if HealthBars[plr] then
                HealthBars[plr].bg.Visible = false
                HealthBars[plr].fill.Visible = false
            end
            if HealthTexts[plr] then HealthTexts[plr].Visible = false end
            continue
        end

        local char = plr.Character
        if not char or not char.Parent then
            -- Если персонажа нет в иерархии - удаляем ESP
            DestroyESP(plr)
            continue
        end

        -- Получаем части персонажа
        local hrp = char:FindFirstChild("HumanoidRootPart") or 
                    char:FindFirstChild("Torso") or 
                    char:FindFirstChild("UpperTorso")
        local head = char:FindFirstChild("Head")
        
        if not hrp or not head then
            box.Visible = false
            if Names[plr] then Names[plr].Visible = false end
            if HealthBars[plr] then
                HealthBars[plr].bg.Visible = false
                HealthBars[plr].fill.Visible = false
            end
            if HealthTexts[plr] then HealthTexts[plr].Visible = false end
            continue
        end

        -- Проверка на врага
        if not IsEnemy(plr) then
            box.Visible = false
            if Names[plr] then Names[plr].Visible = false end
            if HealthBars[plr] then
                HealthBars[plr].bg.Visible = false
                HealthBars[plr].fill.Visible = false
            end
            if HealthTexts[plr] then HealthTexts[plr].Visible = false end
            continue
        end

        -- Проверка на Humanoid
        local humanoid = Humanoids[plr]
        if not humanoid or not humanoid.Parent then
            if not UpdateHumanoid(plr) then
                box.Visible = false
                if Names[plr] then Names[plr].Visible = false end
                if HealthBars[plr] then
                    HealthBars[plr].bg.Visible = false
                    HealthBars[plr].fill.Visible = false
                end
                if HealthTexts[plr] then HealthTexts[plr].Visible = false end
                continue
            end
            humanoid = Humanoids[plr]
        end

        -- Получаем здоровье
        local health, maxHealth = GetSafeHealthValues(humanoid)
        if health <= 0 or maxHealth <= 0 then
            box.Visible = false
            if Names[plr] then Names[plr].Visible = false end
            if HealthBars[plr] then
                HealthBars[plr].bg.Visible = false
                HealthBars[plr].fill.Visible = false
            end
            if HealthTexts[plr] then HealthTexts[plr].Visible = false end
            continue
        end

        -- Получаем позиции на экране
        local rootScreen = WorldToScreen(hrp.Position)
        local headScreen = WorldToScreen(head.Position + Vector3.new(0, 0.5, 0))
        local legScreen = WorldToScreen(hrp.Position - Vector3.new(0, 3, 0))
        
        -- Проверяем видимость
        local rootVisible = IsOnScreen(rootScreen)
        local headVisible = IsOnScreen(headScreen)
        local legVisible = IsOnScreen(legScreen)
        
        if not rootVisible and not headVisible and not legVisible then
            box.Visible = false
            if Names[plr] then Names[plr].Visible = false end
            if HealthBars[plr] then
                HealthBars[plr].bg.Visible = false
                HealthBars[plr].fill.Visible = false
            end
            if HealthTexts[plr] then HealthTexts[plr].Visible = false end
            continue
        end

        -- Проверка дистанции
        local distance = (Camera.CFrame.Position - hrp.Position).Magnitude
        if distance > ESP.Settings.MaxRenderDistance then
            box.Visible = false
            if Names[plr] then Names[plr].Visible = false end
            if HealthBars[plr] then
                HealthBars[plr].bg.Visible = false
                HealthBars[plr].fill.Visible = false
            end
            if HealthTexts[plr] then HealthTexts[plr].Visible = false end
            continue
        end

        -- Используем доступные координаты
        local finalRoot = rootVisible and rootScreen or (headVisible and headScreen or legScreen)
        local finalHead = headVisible and headScreen or (rootVisible and rootScreen or legScreen)
        local finalLeg = legVisible and legScreen or (rootVisible and rootScreen or headScreen)
        
        -- Корректируем Y координаты
        if not headVisible and rootVisible then
            finalHead.Y = finalRoot.Y - 50
        end
        if not legVisible and rootVisible then
            finalLeg.Y = finalRoot.Y + 50
        end
        
        -- Вычисляем размеры
        local height = math.abs(finalHead.Y - finalLeg.Y)
        local width = height * 0.55
        
        -- Защита от слишком маленьких размеров
        if height < 10 or width < 5 then
            box.Visible = false
            if Names[plr] then Names[plr].Visible = false end
            if HealthBars[plr] then
                HealthBars[plr].bg.Visible = false
                HealthBars[plr].fill.Visible = false
            end
            if HealthTexts[plr] then HealthTexts[plr].Visible = false end
            continue
        end

        local healthPercent = health / maxHealth

        -- Обновляем бокс
        if ESP.Settings.EspBox and box then
            box.Size = Vector2.new(width, height)
            box.Position = Vector2.new(finalRoot.X - width/2, finalRoot.Y - height/2)
            box.Color = ESP.Settings.BoxColor
            box.Thickness = ESP.Settings.BoxThickness
            box.Transparency = ESP.Settings.Transparency
            box.Visible = true
        end

        -- Обновляем имя
        if ESP.Settings.EspName and Names[plr] then
            Names[plr].Position = Vector2.new(finalRoot.X, finalRoot.Y - height/2 - 20)
            Names[plr].Color = ESP.Settings.NameColor
            Names[plr].OutlineColor = ESP.Settings.OutlineColor
            Names[plr].Visible = true
        end

        -- Обновляем полоску здоровья
        if ESP.Settings.EspHealthBar and HealthBars[plr] then
            local barWidth = ESP.Settings.HealthBarWidth
            local barHeight = height
            local barX = finalRoot.X - width/2 - barWidth - 2
            local barY = finalRoot.Y - height/2

            local bg = HealthBars[plr].bg
            local fill = HealthBars[plr].fill

            if bg then
                bg.Size = Vector2.new(barWidth, barHeight)
                bg.Position = Vector2.new(barX, barY)
                bg.Visible = true
            end

            if fill then
                local fillHeight = barHeight * healthPercent
                fillHeight = math.max(0, math.min(barHeight, fillHeight))
                
                fill.Color = GetHealthColor(healthPercent)
                fill.Size = Vector2.new(barWidth, fillHeight)
                fill.Position = Vector2.new(barX, barY + (barHeight - fillHeight))
                fill.Visible = true
            end
        end

        -- Обновляем текст здоровья
        if ESP.Settings.EspHealthText and HealthTexts[plr] then
            HealthTexts[plr].Color = GetHealthColor(healthPercent)
            HealthTexts[plr].OutlineColor = ESP.Settings.OutlineColor
            HealthTexts[plr].Text = string.format("%d/%d", math.floor(health), math.floor(maxHealth))
            HealthTexts[plr].Position = Vector2.new(finalRoot.X - width/2 - 35, finalRoot.Y)
            HealthTexts[plr].Visible = true
        end
    end
end)

-- Подключаем события
Players.PlayerAdded:Connect(OnPlayerAdded)
Players.PlayerRemoving:Connect(DestroyESP)

-- Обрабатываем уже существующих игроков
for _, plr in Players:GetPlayers() do
    if plr ~= LocalPlayer then
        OnPlayerAdded(plr)
    end
end

print("ESP loaded - destroys objects when character is removed")
print("Current CameraMode:", LocalPlayer and LocalPlayer.CameraMode)

return ESP
