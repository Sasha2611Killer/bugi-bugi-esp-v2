--// Made by Blissful#4992
--// Modified for Library-style usage with Name ESP from second script

local ESP = {}
local ESP_Instances = {}

--// Settings (can be modified after loading)
ESP.Boxes = true
ESP.Names = true
ESP.ShowDistance = true -- Показывать расстояние
ESP.Box_Color = Color3.fromRGB(0, 255, 50)
ESP.Box_Thickness = 1.4
ESP.Box_Transparency = 1 -- 1 Visible, 0 Not Visible
ESP.Name_Color = Color3.fromRGB(255, 255, 255)
ESP.Name_Size = 19
ESP.Name_Center = true
ESP.Name_Outline = true
ESP.Name_Font = 2 -- 0 = System, 1 = Monospace, 2 = UI, 3 = Bold
ESP.Distance_Offset = 20 -- Смещение расстояния под именем
ESP.Autothickness = false -- Makes screen less encumbered
ESP.Team_Check = false
ESP.Team_Color_Enemy = Color3.fromRGB(227, 52, 52)
ESP.Team_Color_Friendly = Color3.fromRGB(88, 217, 24)
ESP.TeamMates = true -- Показывать тиммейтов

--// Internal variables
local workspace = game:GetService("Workspace")
local player = game:GetService("Players").LocalPlayer
local camera = workspace.CurrentCamera
local players = game:GetService("Players")
local runService = game:GetService("RunService")

--// Helper function to create new drawing objects
local function NewLine()
    local line = Drawing.new("Line")
    line.Visible = false
    line.From = Vector2.new(0, 0)
    line.To = Vector2.new(1, 1)
    line.Color = ESP.Box_Color
    line.Thickness = ESP.Box_Thickness
    line.Transparency = ESP.Box_Transparency
    return line
end

local function NewText()
    local text = Drawing.new("Text")
    text.Visible = false
    text.Text = ""
    text.Color = ESP.Name_Color
    text.Size = ESP.Name_Size
    text.Center = ESP.Name_Center
    text.Outline = ESP.Name_Outline
    text.Font = ESP.Name_Font
    return text
end

--// Team check functions from second script
local function GetTeam(p)
    return p and p.Team
end

local function IsTeamMate(p)
    return GetTeam(p) == GetTeam(player)
end

--// Main ESP function for each player
local function createESPForPlayer(plr)
    if plr == player then return end
    
    --// Create drawing objects
    local instances = {
        -- 12 lines for 3D box
        line1 = NewLine(),
        line2 = NewLine(),
        line3 = NewLine(),
        line4 = NewLine(),
        line5 = NewLine(),
        line6 = NewLine(),
        line7 = NewLine(),
        line8 = NewLine(),
        line9 = NewLine(),
        line10 = NewLine(),
        line11 = NewLine(),
        line12 = NewLine(),
        -- Name text
        nameText = NewText(),
        -- Distance text
        distanceText = NewText()
    }
    
    ESP_Instances[plr] = instances
    
    --// Update function for render loop
    local function updateESP()
        local connection
        connection = runService.RenderStepped:Connect(function()
            -- Check if player is valid
            if plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Head") and plr.Character.Humanoid.Health > 0 then
                
                -- Team check
                if not ESP.TeamMates and IsTeamMate(plr) then
                    -- Hide if team mates are disabled
                    for i = 1, 12 do
                        instances["line"..i].Visible = false
                    end
                    instances.nameText.Visible = false
                    instances.distanceText.Visible = false
                    return
                end
                
                local rootPart = plr.Character.HumanoidRootPart
                local head = plr.Character.Head
                
                -- Get the head position for name placement
                local headPos = head.Position
                local headScreenPos, headVisible = camera:WorldToViewportPoint(headPos)
                
                -- Get root part position for box calculation
                local rootScreenPos, rootVisible = camera:WorldToViewportPoint(rootPart.Position)
                
                if headVisible or rootVisible then
                    -- Calculate box size based on head size
                    local Scale = head.Size.Y/2
                    local Size = Vector3.new(2, 3, 1.5) * (Scale * 2)
                    
                    -- Calculate all 8 corners of the 3D box
                    local Top1 = camera:WorldToViewportPoint((rootPart.CFrame * CFrame.new(-Size.X, Size.Y, -Size.Z)).p)
                    local Top2 = camera:WorldToViewportPoint((rootPart.CFrame * CFrame.new(-Size.X, Size.Y, Size.Z)).p)
                    local Top3 = camera:WorldToViewportPoint((rootPart.CFrame * CFrame.new(Size.X, Size.Y, Size.Z)).p)
                    local Top4 = camera:WorldToViewportPoint((rootPart.CFrame * CFrame.new(Size.X, Size.Y, -Size.Z)).p)
                    
                    local Bottom1 = camera:WorldToViewportPoint((rootPart.CFrame * CFrame.new(-Size.X, -Size.Y, -Size.Z)).p)
                    local Bottom2 = camera:WorldToViewportPoint((rootPart.CFrame * CFrame.new(-Size.X, -Size.Y, Size.Z)).p)
                    local Bottom3 = camera:WorldToViewportPoint((rootPart.CFrame * CFrame.new(Size.X, -Size.Y, Size.Z)).p)
                    local Bottom4 = camera:WorldToViewportPoint((rootPart.CFrame * CFrame.new(Size.X, -Size.Y, -Size.Z)).p)
                    
                    -- Determine colors based on team check
                    local boxColor = ESP.Box_Color
                    local nameColor = ESP.Name_Color
                    
                    if ESP.Team_Check then
                        if IsTeamMate(plr) then
                            boxColor = ESP.Team_Color_Friendly
                            nameColor = ESP.Team_Color_Friendly
                        else
                            boxColor = ESP.Team_Color_Enemy
                            nameColor = ESP.Team_Color_Enemy
                        end
                    end
                    
                    -- Update thickness based on distance
                    local thickness = ESP.Box_Thickness
                    if ESP.Autothickness and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                        local distance = (player.Character.HumanoidRootPart.Position - rootPart.Position).Magnitude
                        thickness = math.clamp(1/distance * 100, 0.1, 4)
                    end
                    
                    -- Update box lines if enabled
                    if ESP.Boxes then
                        -- Top square
                        instances.line1.From = Vector2.new(Top1.X, Top1.Y)
                        instances.line1.To = Vector2.new(Top2.X, Top2.Y)
                        instances.line2.From = Vector2.new(Top2.X, Top2.Y)
                        instances.line2.To = Vector2.new(Top3.X, Top3.Y)
                        instances.line3.From = Vector2.new(Top3.X, Top3.Y)
                        instances.line3.To = Vector2.new(Top4.X, Top4.Y)
                        instances.line4.From = Vector2.new(Top4.X, Top4.Y)
                        instances.line4.To = Vector2.new(Top1.X, Top1.Y)
                        
                        -- Bottom square
                        instances.line5.From = Vector2.new(Bottom1.X, Bottom1.Y)
                        instances.line5.To = Vector2.new(Bottom2.X, Bottom2.Y)
                        instances.line6.From = Vector2.new(Bottom2.X, Bottom2.Y)
                        instances.line6.To = Vector2.new(Bottom3.X, Bottom3.Y)
                        instances.line7.From = Vector2.new(Bottom3.X, Bottom3.Y)
                        instances.line7.To = Vector2.new(Bottom4.X, Bottom4.Y)
                        instances.line8.From = Vector2.new(Bottom4.X, Bottom4.Y)
                        instances.line8.To = Vector2.new(Bottom1.X, Bottom1.Y)
                        
                        -- Vertical lines
                        instances.line9.From = Vector2.new(Bottom1.X, Bottom1.Y)
                        instances.line9.To = Vector2.new(Top1.X, Top1.Y)
                        instances.line10.From = Vector2.new(Bottom2.X, Bottom2.Y)
                        instances.line10.To = Vector2.new(Top2.X, Top2.Y)
                        instances.line11.From = Vector2.new(Bottom3.X, Bottom3.Y)
                        instances.line11.To = Vector2.new(Top3.X, Top3.Y)
                        instances.line12.From = Vector2.new(Bottom4.X, Bottom4.Y)
                        instances.line12.To = Vector2.new(Top4.X, Top4.Y)
                        
                        -- Apply properties to all lines
                        for i = 1, 12 do
                            local line = instances["line"..i]
                            line.Color = boxColor
                            line.Thickness = thickness
                            line.Transparency = ESP.Box_Transparency
                            line.Visible = rootVisible -- Only show box if root part is visible
                        end
                    else
                        -- Hide boxes if disabled
                        for i = 1, 12 do
                            instances["line"..i].Visible = false
                        end
                    end
                    
                    -- Update name text if enabled and head is visible
                    if ESP.Names and headVisible then
                        -- Position name above head
                        local nameY = headScreenPos.Y - 30 -- Position above head
                        
                        -- Name
                        instances.nameText.Position = Vector2.new(headScreenPos.X, nameY)
                        instances.nameText.Text = plr.Name
                        instances.nameText.Color = nameColor
                        instances.nameText.Size = ESP.Name_Size
                        instances.nameText.Center = ESP.Name_Center
                        instances.nameText.Outline = ESP.Name_Outline
                        instances.nameText.Font = ESP.Name_Font
                        instances.nameText.Visible = true
                        
                        -- Distance
                        if ESP.ShowDistance then
                            local distance = math.floor((camera.CFrame.p - rootPart.Position).Magnitude)
                            instances.distanceText.Position = Vector2.new(headScreenPos.X, nameY + ESP.Distance_Offset)
                            instances.distanceText.Text = distance .. "m"
                            instances.distanceText.Color = nameColor
                            instances.distanceText.Size = ESP.Name_Size - 2
                            instances.distanceText.Center = ESP.Name_Center
                            instances.distanceText.Outline = ESP.Name_Outline
                            instances.distanceText.Font = ESP.Name_Font
                            instances.distanceText.Visible = true
                        else
                            instances.distanceText.Visible = false
                        end
                    else
                        instances.nameText.Visible = false
                        instances.distanceText.Visible = false
                    end
                    
                else
                    -- Hide everything if player is not visible
                    for i = 1, 12 do
                        instances["line"..i].Visible = false
                    end
                    instances.nameText.Visible = false
                    instances.distanceText.Visible = false
                end
            else
                -- Hide everything if player is invalid
                for i = 1, 12 do
                    instances["line"..i].Visible = false
                end
                instances.nameText.Visible = false
                instances.distanceText.Visible = false
                
                -- Disconnect if player is removed
                if not players:FindFirstChild(plr.Name) then
                    connection:Disconnect()
                    ESP_Instances[plr] = nil
                end
            end
        end)
    end
    
    coroutine.wrap(updateESP)()
end

--// Initialize ESP for existing players
for _, plr in pairs(players:GetPlayers()) do
    createESPForPlayer(plr)
end

--// Handle new players joining
players.PlayerAdded:Connect(function(plr)
    createESPForPlayer(plr)
end)

--// Handle players leaving
players.PlayerRemoving:Connect(function(plr)
    if ESP_Instances[plr] then
        -- Clean up drawing objects
        for _, instance in pairs(ESP_Instances[plr]) do
            instance:Remove()
        end
        ESP_Instances[plr] = nil
    end
end)

--// Return the ESP table for external use
return ESP
