--// Locals:
local workspace = game:GetService("Workspace")
local players = game:GetService("Players")
local player = players.LocalPlayer
local camera = workspace.CurrentCamera
local runService = game:GetService("RunService")

--// Settings:
local on = true -- Включить/выключить ESP

-- Box settings
local Box_Color = Color3.fromRGB(0, 255, 50)
local Box_Thickness = 1.4
local Box_Transparency = 0 -- 0 = Visible, 1 = Invisible (ИСПРАВЛЕНО!)
local Box_Scale = 1.0 -- Множитель размера бокса

-- Team check settings
local Team_Check = false
local Team_Color_Ally = Color3.fromRGB(88, 217, 24)  -- Green for allies
local Team_Color_Enemy = Color3.fromRGB(227, 52, 52) -- Red for enemies

-- Name ESP Settings
local Show_Names = true
local Name_Color = Color3.fromRGB(255, 255, 255)
local Name_Size = 16
local Show_Distance = true
local Distance_Color = Color3.fromRGB(200, 200, 200)

-- Advanced settings
local Autothickness = false -- Автоматическая толщина линий в зависимости от расстояния
local Min_Thickness = 0.5   -- Минимальная толщина
local Max_Thickness = 3.0   -- Максимальная толщина
local Max_Distance = 300    -- Максимальная дистанция отображения

--// Helper Functions:
local function NewLine()
    local line = Drawing.new("Line")
    line.Visible = false
    line.From = Vector2.new(0, 0)
    line.To = Vector2.new(1, 1)
    line.Color = Box_Color
    line.Thickness = Box_Thickness
    line.Transparency = Box_Transparency
    return line
end

local function NewText()
    local text = Drawing.new("Text")
    text.Visible = false
    text.Center = true
    text.Outline = true
    text.Size = Name_Size
    text.Color = Name_Color
    text.Font = 3 -- 0 = UI, 1 = System, 2 = Plex, 3 = Monospace
    return text
end

local function IsCharacterValid(character)
    return character and 
           character:FindFirstChild("Humanoid") and 
           character:FindFirstChild("HumanoidRootPart") and 
           character:FindFirstChild("Head") and
           character.Humanoid.Health > 0
end

local function IsOnScreen(position)
    local vector, onScreen = camera:WorldToViewportPoint(position)
    return onScreen and vector.Z > 0
end

local function GetTeamColor(plr)
    if Team_Check and plr and player then
        return (plr.Team == player.Team) and Team_Color_Ally or Team_Color_Enemy
    end
    return Box_Color
end

--// Box Drawing Class
local BoxESP = {}
BoxESP.__index = BoxESP

function BoxESP.new(targetPlayer)
    local self = setmetatable({}, BoxESP)
    
    self.Player = targetPlayer
    self.Character = targetPlayer.Character
    self.Connections = {}
    self.Lines = {}
    self.NameText = NewText()
    self.DistanceText = NewText()
    self.Visible = false
    self.Color = Box_Color
    
    -- Create 12 lines for 3D box
    for i = 1, 12 do
        self.Lines[i] = NewLine()
    end
    
    -- Character added/removed connections
    local charAddedConn
    charAddedConn = targetPlayer.CharacterAdded:Connect(function(character)
        self.Character = character
        -- Wait for character to load
        character:WaitForChild("HumanoidRootPart", 5)
        character:WaitForChild("Head", 5)
    end)
    table.insert(self.Connections, charAddedConn)
    
    local charRemovingConn
    charRemovingConn = targetPlayer.CharacterRemoving:Connect(function()
        self.Character = nil
        self:SetVisible(false)
    end)
    table.insert(self.Connections, charRemovingConn)
    
    return self
end

function BoxESP:SetVisible(visible)
    self.Visible = visible
    for _, line in pairs(self.Lines) do
        line.Visible = visible
    end
    if Show_Names then
        self.NameText.Visible = visible and Show_Names
        self.DistanceText.Visible = visible and Show_Distance
    end
end

function BoxESP:Update()
    -- Проверка валидности
    if not on or not self.Player or self.Player == player then
        self:SetVisible(false)
        return
    end
    
    -- Проверка персонажа
    if not IsCharacterValid(self.Character) then
        self:SetVisible(false)
        return
    end
    
    local humanoidRootPart = self.Character.HumanoidRootPart
    local head = self.Character.Head
    
    -- Проверка дистанции
    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local distance = (player.Character.HumanoidRootPart.Position - humanoidRootPart.Position).magnitude
        if distance > Max_Distance then
            self:SetVisible(false)
            return
        end
    end
    
    -- Проверка видимости на экране
    local rootPos = humanoidRootPart.Position
    local onScreen = IsOnScreen(rootPos)
    
    if not onScreen then
        self:SetVisible(false)
        return
    end
    
    -- Определение цвета (team check)
    self.Color = GetTeamColor(self.Player)
    
    -- Расчет размеров бокса (адаптивный размер)
    local headSize = head.Size.Y
    local scale = (headSize / 2) * Box_Scale
    local size = Vector3.new(2 * scale, 3 * scale, 1.5 * scale)
    
    -- Получение угловых точек бокса
    local function getCorner(offset)
        local success, result = pcall(function()
            return camera:WorldToViewportPoint((humanoidRootPart.CFrame * offset).p)
        end)
        return success and result or Vector3.new(0, 0, 0)
    end
    
    -- Верхние углы
    local Top1 = getCorner(CFrame.new(-size.X, size.Y, -size.Z))
    local Top2 = getCorner(CFrame.new(-size.X, size.Y, size.Z))
    local Top3 = getCorner(CFrame.new(size.X, size.Y, size.Z))
    local Top4 = getCorner(CFrame.new(size.X, size.Y, -size.Z))
    
    -- Нижние углы
    local Bottom1 = getCorner(CFrame.new(-size.X, -size.Y, -size.Z))
    local Bottom2 = getCorner(CFrame.new(-size.X, -size.Y, size.Z))
    local Bottom3 = getCorner(CFrame.new(size.X, -size.Y, size.Z))
    local Bottom4 = getCorner(CFrame.new(size.X, -size.Y, -size.Z))
    
    -- Обновление линий (верх)
    self.Lines[1].From = Vector2.new(Top1.X, Top1.Y)
    self.Lines[1].To = Vector2.new(Top2.X, Top2.Y)
    
    self.Lines[2].From = Vector2.new(Top2.X, Top2.Y)
    self.Lines[2].To = Vector2.new(Top3.X, Top3.Y)
    
    self.Lines[3].From = Vector2.new(Top3.X, Top3.Y)
    self.Lines[3].To = Vector2.new(Top4.X, Top4.Y)
    
    self.Lines[4].From = Vector2.new(Top4.X, Top4.Y)
    self.Lines[4].To = Vector2.new(Top1.X, Top1.Y)
    
    -- Обновление линий (низ)
    self.Lines[5].From = Vector2.new(Bottom1.X, Bottom1.Y)
    self.Lines[5].To = Vector2.new(Bottom2.X, Bottom2.Y)
    
    self.Lines[6].From = Vector2.new(Bottom2.X, Bottom2.Y)
    self.Lines[6].To = Vector2.new(Bottom3.X, Bottom3.Y)
    
    self.Lines[7].From = Vector2.new(Bottom3.X, Bottom3.Y)
    self.Lines[7].To = Vector2.new(Bottom4.X, Bottom4.Y)
    
    self.Lines[8].From = Vector2.new(Bottom4.X, Bottom4.Y)
    self.Lines[8].To = Vector2.new(Bottom1.X, Bottom1.Y)
    
    -- Обновление линий (вертикальные)
    self.Lines[9].From = Vector2.new(Bottom1.X, Bottom1.Y)
    self.Lines[9].To = Vector2.new(Top1.X, Top1.Y)
    
    self.Lines[10].From = Vector2.new(Bottom2.X, Bottom2.Y)
    self.Lines[10].To = Vector2.new(Top2.X, Top2.Y)
    
    self.Lines[11].From = Vector2.new(Bottom3.X, Bottom3.Y)
    self.Lines[11].To = Vector2.new(Top3.X, Top3.Y)
    
    self.Lines[12].From = Vector2.new(Bottom4.X, Bottom4.Y)
    self.Lines[12].To = Vector2.new(Top4.X, Top4.Y)
    
    -- Применение цвета и толщины ко всем линиям
    for i = 1, 12 do
        self.Lines[i].Color = self.Color
        if Autothickness and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local distance = (player.Character.HumanoidRootPart.Position - humanoidRootPart.Position).magnitude
            local thickness = math.clamp(1/distance * 100, Min_Thickness, Max_Thickness)
            self.Lines[i].Thickness = thickness
        else
            self.Lines[i].Thickness = Box_Thickness
        end
        self.Lines[i].Transparency = Box_Transparency
    end
    
    -- Обновление текста (имя и дистанция)
    if Show_Names then
        local headPos = camera:WorldToViewportPoint(head.Position + Vector3.new(0, 1.5, 0))
        
        -- Имя игрока
        self.NameText.Position = Vector2.new(headPos.X, headPos.Y - 35)
        self.NameText.Text = self.Player.Name
        self.NameText.Color = self.Color
        self.NameText.Size = Name_Size
        self.NameText.Visible = true
        
        -- Дистанция
        if Show_Distance and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local distance = (player.Character.HumanoidRootPart.Position - humanoidRootPart.Position).magnitude
            self.DistanceText.Position = Vector2.new(headPos.X, headPos.Y - 15)
            self.DistanceText.Text = string.format("%.0f m", distance)
            self.DistanceText.Color = Distance_Color
            self.DistanceText.Size = Name_Size - 2
            self.DistanceText.Visible = true
        end
    end
    
    -- Включаем видимость всех элементов
    self:SetVisible(true)
end

function BoxESP:Destroy()
    self:SetVisible(false)
    
    -- Удаление всех линий
    for _, line in pairs(self.Lines) do
        pcall(function()
            line:Remove()
        end)
    end
    self.Lines = {}
    
    -- Удаление текста
    pcall(function()
        self.NameText:Remove()
        self.DistanceText:Remove()
    end)
    
    -- Отключение соединений
    for _, conn in pairs(self.Connections) do
        pcall(function()
            conn:Disconnect()
        end)
    end
    self.Connections = {}
end

--// Main ESP Manager
local ESPManager = {
    Boxes = {},
    Connections = {}
}

function ESPManager:Initialize()
    -- Очистка старых данных
    self:Cleanup()
    
    -- Создание боксов для существующих игроков
    for _, plr in pairs(players:GetPlayers()) do
        if plr ~= player then
            self:AddPlayer(plr)
        end
    end
    
    -- Подключение событий
    local playerAddedConn = players.PlayerAdded:Connect(function(plr)
        if plr ~= player then
            self:AddPlayer(plr)
        end
    end)
    table.insert(self.Connections, playerAddedConn)
    
    local playerRemovedConn = players.PlayerRemoving:Connect(function(plr)
        self:RemovePlayer(plr)
    end)
    table.insert(self.Connections, playerRemovedConn)
    
    -- Запуск рендер-лупа
    self:StartRenderLoop()
end

function ESPManager:AddPlayer(plr)
    if self.Boxes[plr] then
        self.Boxes[plr]:Destroy()
    end
    self.Boxes[plr] = BoxESP.new(plr)
end

function ESPManager:RemovePlayer(plr)
    if self.Boxes[plr] then
        self.Boxes[plr]:Destroy()
        self.Boxes[plr] = nil
    end
end

function ESPManager:StartRenderLoop()
    local renderConn = runService.RenderStepped:Connect(function()
        -- Обновление камеры на случай смены
        camera = workspace.CurrentCamera or camera
        
        -- Обновление всех боксов
        for plr, box in pairs(self.Boxes) do
            local success, err = pcall(function()
                box:Update()
            end)
            
            if not success then
                warn(string.format("Error updating ESP for %s: %s", plr.Name, err))
                -- В случае ошибки пересоздаем бокс
                self:RemovePlayer(plr)
                self:AddPlayer(plr)
            end
        end
    end)
    table.insert(self.Connections, renderConn)
end

function ESPManager:Cleanup()
    -- Удаление всех боксов
    for plr, box in pairs(self.Boxes) do
        pcall(function()
            box:Destroy()
        end)
    end
    self.Boxes = {}
    
    -- Отключение всех соединений
    for _, conn in pairs(self.Connections) do
        pcall(function()
            conn:Disconnect()
        end)
    end
    self.Connections = {}
end

--// GUI Control Functions (опционально)
local function ToggleESP(state)
    on = state
    if not on then
        for _, box in pairs(ESPManager.Boxes) do
            box:SetVisible(false)
        end
    end
end

local function UpdateSettings(newSettings)
    if newSettings.Box_Color then Box_Color = newSettings.Box_Color end
    if newSettings.Team_Check ~= nil then Team_Check = newSettings.Team_Check end
    if newSettings.Show_Names ~= nil then Show_Names = newSettings.Show_Names end
    if newSettings.Show_Distance ~= nil then Show_Distance = newSettings.Show_Distance end
    if newSettings.Box_Thickness then Box_Thickness = newSettings.Box_Thickness end
    if newSettings.Box_Scale then Box_Scale = newSettings.Box_Scale end
    if newSettings.Max_Distance then Max_Distance = newSettings.Max_Distance end
end

--// Инициализация
local success, err = pcall(function()
    ESPManager:Initialize()
end)

if not success then
    warn("Failed to initialize ESP: " .. tostring(err))
end

--// Cleanup on script end (если используется в скрипте, а не в консоли)
