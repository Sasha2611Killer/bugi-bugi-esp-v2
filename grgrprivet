--// Locals:
local workspace = game:GetService("Workspace")
local player = game:GetService("Players").LocalPlayer
local camera = workspace.CurrentCamera

--// ESP Table with Settings
local ESP = {
    Enabled = true,
    Boxes = true,
    Names = true,
    Tracers = false,
    TeamCheck = false,
    Autothickness = false,
    
    -- Visual Settings
    BoxColor = Color3.fromRGB(0, 255, 50),
    BoxThickness = 1.4,
    BoxTransparency = 1, -- 1 = полностью видимый, 0 = невидимый
    
    TracerColor = Color3.fromRGB(0, 255, 50),
    TracerThickness = 1.4,
    TracerTransparency = 1,
    
    NameColor = Color3.fromRGB(255, 255, 255),
    NameSize = 16,
    DistanceColor = Color3.fromRGB(200, 200, 200),
    
    -- Team Colors
    TeamColorEnemy = Color3.fromRGB(227, 52, 52),
    TeamColorFriend = Color3.fromRGB(88, 217, 24)
}

--// Helper function for team check
local function IsEnemy(plr)
    if plr == player then return false end
    local localTeam = player:GetAttribute("Team")
    local playerTeam = plr:GetAttribute("Team")
    if not localTeam or not playerTeam then return false end
    return localTeam ~= playerTeam
end

--// Helper Functions
local function NewLine()
    local line = Drawing.new("Line")
    line.Visible = false
    line.From = Vector2.new(0, 0)
    line.To = Vector2.new(1, 1)
    line.Color = ESP.BoxColor
    line.Thickness = ESP.BoxThickness
    line.Transparency = 1 -- 1 = видимый (исправлено)
    return line
end

local function NewText()
    local text = Drawing.new("Text")
    text.Visible = false
    text.Center = true
    text.Outline = true
    text.Size = ESP.NameSize
    text.Color = ESP.NameColor
    text.Transparency = 1 -- Добавляем прозрачность для текста
    return text
end

--// Main Function to create ESP for a player
local function CreateESPForPlayer(targetPlayer)
    --// Lines for 3D box (12)
    local lines = {
        line1 = NewLine(),
        line2 = NewLine(),
        line3 = NewLine(),
        line4 = NewLine(),
        line5 = NewLine(),
        line6 = NewLine(),
        line7 = NewLine(),
        line8 = NewLine(),
        line9 = NewLine(),
        line10 = NewLine(),
        line11 = NewLine(),
        line12 = NewLine(),
        Tracer = NewLine(),
        NameText = NewText(),
        DistanceText = NewText()
    }
    
    -- Set tracer properties
    lines.Tracer.Color = ESP.TracerColor
    lines.Tracer.Thickness = ESP.TracerThickness
    lines.Tracer.Transparency = 1

    --// Updates ESP in render loop
    local function UpdateESP()
        local connection
        connection = game:GetService("RunService").RenderStepped:Connect(function()
            -- Проверяем включен ли ESP
            if not ESP.Enabled then
                for _, line in pairs(lines) do
                    line.Visible = false
                end
                return
            end
            
            -- Проверяем валидность игрока
            if targetPlayer.Character and 
               targetPlayer.Character:FindFirstChild("Humanoid") and 
               targetPlayer.Character:FindFirstChild("HumanoidRootPart") and 
               targetPlayer.Name ~= player.Name and 
               targetPlayer.Character.Humanoid.Health > 0 and 
               targetPlayer.Character:FindFirstChild("Head") and
               player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                
                local pos, vis = camera:WorldToViewportPoint(targetPlayer.Character.HumanoidRootPart.Position)
                if vis then
                    local Scale = targetPlayer.Character.Head.Size.Y/2
                    local Size = Vector3.new(2, 3, 1.5) * (Scale * 2)
                    
                    -- Calculate box corners
                    local Top1 = camera:WorldToViewportPoint((targetPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(-Size.X, Size.Y, -Size.Z)).p)
                    local Top2 = camera:WorldToViewportPoint((targetPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(-Size.X, Size.Y, Size.Z)).p)
                    local Top3 = camera:WorldToViewportPoint((targetPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(Size.X, Size.Y, Size.Z)).p)
                    local Top4 = camera:WorldToViewportPoint((targetPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(Size.X, Size.Y, -Size.Z)).p)
                    
                    local Bottom1 = camera:WorldToViewportPoint((targetPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(-Size.X, -Size.Y, -Size.Z)).p)
                    local Bottom2 = camera:WorldToViewportPoint((targetPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(-Size.X, -Size.Y, Size.Z)).p)
                    local Bottom3 = camera:WorldToViewportPoint((targetPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(Size.X, -Size.Y, Size.Z)).p)
                    local Bottom4 = camera:WorldToViewportPoint((targetPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(Size.X, -Size.Y, -Size.Z)).p)
                    
                    -- Determine color based on team
                    local currentColor = ESP.BoxColor
                    if ESP.TeamCheck then
                        if IsEnemy(targetPlayer) then
                            currentColor = ESP.TeamColorEnemy
                        else
                            currentColor = ESP.TeamColorFriend
                        end
                    end
                    
                    -- Update box lines (if enabled)
                    if ESP.Boxes then
                        -- Top square
                        lines.line1.From = Vector2.new(Top1.X, Top1.Y); lines.line1.To = Vector2.new(Top2.X, Top2.Y)
                        lines.line2.From = Vector2.new(Top2.X, Top2.Y); lines.line2.To = Vector2.new(Top3.X, Top3.Y)
                        lines.line3.From = Vector2.new(Top3.X, Top3.Y); lines.line3.To = Vector2.new(Top4.X, Top4.Y)
                        lines.line4.From = Vector2.new(Top4.X, Top4.Y); lines.line4.To = Vector2.new(Top1.X, Top1.Y)
                        
                        -- Bottom square
                        lines.line5.From = Vector2.new(Bottom1.X, Bottom1.Y); lines.line5.To = Vector2.new(Bottom2.X, Bottom2.Y)
                        lines.line6.From = Vector2.new(Bottom2.X, Bottom2.Y); lines.line6.To = Vector2.new(Bottom3.X, Bottom3.Y)
                        lines.line7.From = Vector2.new(Bottom3.X, Bottom3.Y); lines.line7.To = Vector2.new(Bottom4.X, Bottom4.Y)
                        lines.line8.From = Vector2.new(Bottom4.X, Bottom4.Y); lines.line8.To = Vector2.new(Bottom1.X, Bottom1.Y)
                        
                        -- Vertical lines
                        lines.line9.From = Vector2.new(Bottom1.X, Bottom1.Y); lines.line9.To = Vector2.new(Top1.X, Top1.Y)
                        lines.line10.From = Vector2.new(Bottom2.X, Bottom2.Y); lines.line10.To = Vector2.new(Top2.X, Top2.Y)
                        lines.line11.From = Vector2.new(Bottom3.X, Bottom3.Y); lines.line11.To = Vector2.new(Top3.X, Top3.Y)
                        lines.line12.From = Vector2.new(Bottom4.X, Bottom4.Y); lines.line12.To = Vector2.new(Top4.X, Top4.Y)
                        
                        -- Set colors and visibility
                        for i = 1, 12 do
                            lines["line"..i].Color = currentColor
                            lines["line"..i].Visible = true
                        end
                    else
                        for i = 1, 12 do
                            lines["line"..i].Visible = false
                        end
                    end
                    
                    -- Update tracer (if enabled)
                    if ESP.Tracers then
                        local trace = camera:WorldToViewportPoint((targetPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0, -Size.Y, 0)).p)
                        lines.Tracer.From = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y)
                        lines.Tracer.To = Vector2.new(trace.X, trace.Y)
                        lines.Tracer.Color = currentColor
                        lines.Tracer.Visible = true
                    else
                        lines.Tracer.Visible = false
                    end
                    
                    -- Update name text (if enabled)
                    if ESP.Names then
                        local headPos = camera:WorldToViewportPoint(targetPlayer.Character.Head.Position + Vector3.new(0, 1.5, 0))
                        lines.NameText.Position = Vector2.new(headPos.X, headPos.Y - 30)
                        lines.NameText.Text = targetPlayer.Name
                        lines.NameText.Color = currentColor
                        lines.NameText.Visible = true
                        
                        -- Distance text
                        local distance = (player.Character.HumanoidRootPart.Position - targetPlayer.Character.HumanoidRootPart.Position).magnitude
                        lines.DistanceText.Position = Vector2.new(headPos.X, headPos.Y - 15)
                        lines.DistanceText.Text = math.floor(distance) .. "m"
                        lines.DistanceText.Color = ESP.DistanceColor
                        lines.DistanceText.Visible = true
                    else
                        lines.NameText.Visible = false
                        lines.DistanceText.Visible = false
                    end
                    
                    -- Apply autothickness
                    if ESP.Autothickness then
                        local distance = (player.Character.HumanoidRootPart.Position - targetPlayer.Character.HumanoidRootPart.Position).magnitude
                        local value = math.clamp(1/distance*100, 0.1, 4)
                        for i = 1, 12 do
                            lines["line"..i].Thickness = value
                        end
                        lines.Tracer.Thickness = value
                    end
                    
                else
                    -- Player not visible on screen
                    for _, line in pairs(lines) do
                        line.Visible = false
                    end
                end
            else
                -- Player invalid
                for _, line in pairs(lines) do
                    line.Visible = false
                end
                if game.Players:FindFirstChild(targetPlayer.Name) == nil then
                    if connection then
                        connection:Disconnect()
                    end
                end
            end
        end)
    end
    
    coroutine.wrap(UpdateESP)()
end

--// Initialize for existing players
for _, v in pairs(game.Players:GetPlayers()) do
    if v ~= player then
        CreateESPForPlayer(v)
    end
end

--// Handle new players
game.Players.PlayerAdded:Connect(function(newplr)
    if newplr ~= player then
        CreateESPForPlayer(newplr)
    end
end)

--// ВАЖНО: Активируем ESP сразу после загрузки
ESP.Enabled = true

--// Возвращаем таблицу для внешнего использования
return ESP
