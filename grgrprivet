local ESP = {}
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- Настройки ESP (изменяйте их в любое время - всё обновится автоматически)
ESP.Settings = {
    Enabled = true,           -- Включить/выключить ESP
    EspBox = true,            -- Показывать бокс
    EspName = true,           -- Показывать имя
    EspHealthBar = true,      -- Показывать полоску здоровья
    EspHealthText = true,     -- Показывать текст здоровья
    BoxColor = Color3.fromRGB(255, 0, 0),        -- Цвет бокса
    NameColor = Color3.fromRGB(255, 255, 255),   -- Цвет имени
    HealthBarWidth = 6,       -- Ширина полоски здоровья
    OutlineColor = Color3.fromRGB(0, 0, 0),      -- Цвет обводки
    Transparency = 1,         -- Прозрачность
    ShowTeammates = false,    -- Показывать тиммейтов
    ShowEnemies = true,       -- Показывать врагов
    ShowSelf = false,         -- Показывать себя
    BoxThickness = 1.6,       -- Толщина бокса
    MaxRenderDistance = 1000,  -- Максимальная дистанция отрисовки (опционально)
}

-- Внутренние переменные
local Boxes = {}
local Names = {}
local HealthBars = {}
local HealthTexts = {}
local Humanoids = {}
local Connections = {}
local PlayerData = {}

-- Кэш для оптимизации
local ViewportCache = {}
local CACHE_DURATION = 0.1 -- Обновление кэша каждые 0.1 секунды

-- Функция для проверки, враг ли игрок
local function IsEnemy(plr)
    if plr == LocalPlayer then 
        return ESP.Settings.ShowSelf
    end

    -- Защита от nil
    local myChar = LocalPlayer.Character
    local theirChar = plr.Character
    if not myChar or not theirChar then return false end

    -- Безопасное получение имени команды
    local myTeamName = "Enemy"
    local theirTeamName = "Enemy"
    
    local success, result = pcall(function()
        return myChar.Parent.Name
    end)
    if success and result then
        myTeamName = result
    end
    
    success, result = pcall(function()
        return theirChar.Parent.Name
    end)
    if success and result then
        theirTeamName = result
    end

    local isEnemy = myTeamName ~= theirTeamName

    if isEnemy then
        return ESP.Settings.ShowEnemies
    else
        return ESP.Settings.ShowTeammates
    end
end

-- Функция для получения Humanoid
local function GetHumanoid(character)
    if not character then return nil end
    -- Прямой поиск быстрее
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        return humanoid
    end
    return nil
end

-- Очистка данных игрока
local function ClearPlayerData(plr)
    Humanoids[plr] = nil
    PlayerData[plr] = nil
    ViewportCache[plr] = nil
end

-- Обновление Humanoid
local function UpdateHumanoid(plr)
    local char = plr.Character
    if char then
        local newHumanoid = GetHumanoid(char)
        if newHumanoid and newHumanoid.Health > 0 then
            Humanoids[plr] = newHumanoid
            PlayerData[plr] = {
                lastUpdate = tick(),
                valid = true
            }
            return true
        end
    end

    ClearPlayerData(plr)
    return false
end

-- Очистка соединений
local function ClearConnections(plr)
    if Connections[plr] then
        for _, conn in pairs(Connections[plr]) do
            pcall(function() conn:Disconnect() end)
        end
        Connections[plr] = nil
    end
end

-- Спрятать весь ESP для игрока
local function HideAllESP(plr)
    local function setVisible(obj, visible)
        if obj then
            obj.Visible = visible
        end
    end

    if Boxes[plr] then
        Boxes[plr].Visible = false
    end
    if Names[plr] then
        Names[plr].Visible = false
    end
    if HealthBars[plr] then
        setVisible(HealthBars[plr].bg, false)
        setVisible(HealthBars[plr].fill, false)
    end
    if HealthTexts[plr] then
        HealthTexts[plr].Visible = false
    end
end

-- Создание ESP для игрока
local function CreateESP(plr)
    if Boxes[plr] then return end

    -- Создаем все объекты сразу
    local box = Drawing.new("Square")
    box.Thickness = ESP.Settings.BoxThickness
    box.Filled = false
    box.Color = ESP.Settings.BoxColor
    box.Transparency = ESP.Settings.Transparency
    box.Visible = false
    Boxes[plr] = box

    local nameTag = Drawing.new("Text")
    nameTag.Text = plr.Name
    nameTag.Size = 16
    nameTag.Color = ESP.Settings.NameColor
    nameTag.Center = true
    nameTag.Outline = true
    nameTag.OutlineColor = ESP.Settings.OutlineColor
    nameTag.Visible = false
    Names[plr] = nameTag

    local healthBarBg = Drawing.new("Square")
    healthBarBg.Thickness = 1
    healthBarBg.Filled = true
    healthBarBg.Color = Color3.fromRGB(0, 0, 0)
    healthBarBg.Transparency = 0.7
    healthBarBg.Visible = false
    
    local healthBarFill = Drawing.new("Square")
    healthBarFill.Thickness = 1
    healthBarFill.Filled = true
    healthBarFill.Color = Color3.fromRGB(0, 255, 0)
    healthBarFill.Transparency = 0.7
    healthBarFill.Visible = false
    
    HealthBars[plr] = {bg = healthBarBg, fill = healthBarFill}

    local healthText = Drawing.new("Text")
    healthText.Size = 14
    healthText.Color = Color3.fromRGB(255, 255, 255)
    healthText.Center = true
    healthText.Outline = true
    healthText.OutlineColor = ESP.Settings.OutlineColor
    healthText.Visible = false
    HealthTexts[plr] = healthText
end

-- Удаление ESP для игрока
local function RemoveESP(plr)
    local function safeRemove(obj)
        pcall(function() obj:Remove() end)
    end

    safeRemove(Boxes[plr])
    Boxes[plr] = nil
    
    safeRemove(Names[plr])
    Names[plr] = nil
    
    if HealthBars[plr] then
        safeRemove(HealthBars[plr].bg)
        safeRemove(HealthBars[plr].fill)
        HealthBars[plr] = nil
    end
    
    safeRemove(HealthTexts[plr])
    HealthTexts[plr] = nil

    ClearPlayerData(plr)
    ClearConnections(plr)
end

-- Получение цвета здоровья
local function GetHealthColor(percent)
    percent = math.max(0, math.min(1, percent))
    
    if percent > 0.6 then
        return Color3.fromRGB(0, 255, 0)
    elseif percent > 0.3 then
        return Color3.fromRGB(255, 255, 0)
    elseif percent > 0.1 then
        return Color3.fromRGB(255, 100, 0)
    else
        return Color3.fromRGB(255, 0, 0)
    end
end

-- Безопасное получение значений здоровья
local function GetSafeHealthValues(humanoid)
    if not humanoid then
        return 0, 100
    end

    local maxHealth = 100
    local success, result = pcall(function()
        return humanoid.MaxHealth
    end)
    if success and result and result > 0 then
        maxHealth = result
    end

    local health = 0
    success, result = pcall(function()
        return humanoid.Health
    end)
    if success and result and result >= 0 then
        health = result
    end

    -- Защита от некорректных значений
    if health > maxHealth * 2 then
        health = maxHealth
    end

    return health, maxHealth
end

-- Оптимизированная проверка видимости
local function IsOnScreen(position)
    -- Используем pcall для безопасности
    local success, vector = pcall(function()
        return Camera:WorldToViewportPoint(position)
    end)
    
    if not success or not vector then
        return false, Vector3.new()
    end
    
    -- Проверяем, что точка перед камерой и в пределах экрана
    local onScreen = vector.Z > 0.1 and vector.X >= 0 and vector.X <= Camera.ViewportSize.X 
                    and vector.Y >= 0 and vector.Y <= Camera.ViewportSize.Y
    
    return onScreen, vector
end

-- Отслеживание смерти и изменений здоровья
local function TrackDeath(plr, humanoid)
    if not humanoid then return end

    -- Только одно соединение на изменения здоровья
    if not Connections[plr] then
        Connections[plr] = {}
    end

    local healthChangedConn = humanoid:GetPropertyChangedSignal("Health"):Connect(function()
        -- Просто отмечаем, что нужно обновить в следующем кадре
        PlayerData[plr] = PlayerData[plr] or {}
        PlayerData[plr].healthChanged = true
    end)
    table.insert(Connections[plr], healthChangedConn)

    local diedConn = humanoid.Died:Connect(function()
        ClearPlayerData(plr)
        
        -- Небольшая задержка перед проверкой респавна
        task.wait(2)
        
        if plr.Character and plr.Character.Parent then
            UpdateHumanoid(plr)
        end
    end)
    table.insert(Connections[plr], diedConn)
end

-- Обработка добавления персонажа
local function OnCharacterAdded(plr, char)
    ClearPlayerData(plr)
    ClearConnections(plr)

    Connections[plr] = {}

    -- Небольшая задержка для инициализации персонажа
    task.wait(0.3)

    UpdateHumanoid(plr)

    local humanoid = Humanoids[plr]
    if humanoid then
        TrackDeath(plr, humanoid)
    end

    -- Отслеживаем новые части
    local childAddedConn = char.ChildAdded:Connect(function(child)
        if child:IsA("Humanoid") then
            UpdateHumanoid(plr)
            TrackDeath(plr, child)
        end
    end)
    table.insert(Connections[plr], childAddedConn)

    -- Отслеживаем удаление персонажа
    local charRemovedConn = char.AncestryChanged:Connect(function()
        if not char.Parent then
            ClearPlayerData(plr)
        end
    end)
    table.insert(Connections[plr], charRemovedConn)
end

-- Обработка добавления игрока
local function OnPlayerAdded(plr)
    if plr == LocalPlayer and not ESP.Settings.ShowSelf then 
        return 
    end

    CreateESP(plr)

    local charAddedConn = plr.CharacterAdded:Connect(function(char)
        OnCharacterAdded(plr, char)
    end)

    if not Connections[plr] then
        Connections[plr] = {}
    end
    table.insert(Connections[plr], charAddedConn)

    if plr.Character then
        OnCharacterAdded(plr, plr.Character)
    end
end

-- Отслеживаем изменения в настройках
local SettingsMetatable = {
    __newindex = function(t, key, value)
        rawset(t, key, value)

        if key == "BoxColor" or key == "BoxThickness" then
            for _, box in pairs(Boxes) do
                if box then
                    box.Color = ESP.Settings.BoxColor
                    box.Thickness = ESP.Settings.BoxThickness
                end
            end
        elseif key == "NameColor" or key == "OutlineColor" then
            for _, nameTag in pairs(Names) do
                if nameTag then
                    nameTag.Color = ESP.Settings.NameColor
                    nameTag.OutlineColor = ESP.Settings.OutlineColor
                end
            end
            for _, healthText in pairs(HealthTexts) do
                if healthText then
                    healthText.OutlineColor = ESP.Settings.OutlineColor
                end
            end
        end
    end
}

setmetatable(ESP.Settings, SettingsMetatable)

-- Оптимизированный основной цикл
local lastTime = 0
local UPDATE_INTERVAL = 1/30 -- Обновление 30 FPS для ESP

RunService.RenderStepped:Connect(function()
    local currentTime = tick()
    
    -- Ограничиваем частоту обновления для производительности
    if currentTime - lastTime < UPDATE_INTERVAL then
        return
    end
    lastTime = currentTime

    for plr, box in pairs(Boxes) do
        -- Быстрые проверки
        if plr == LocalPlayer and not ESP.Settings.ShowSelf then
            HideAllESP(plr)
            continue
        end

        if not ESP.Settings.Enabled then
            HideAllESP(plr)
            continue
        end

        -- Получаем персонажа
        local char = plr.Character
        if not char or not char.Parent then
            HideAllESP(plr)
            continue
        end

        -- Получаем части
        local hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
        local head = char:FindFirstChild("Head")
        
        if not hrp or not head then
            HideAllESP(plr)
            continue
        end

        -- Проверка на врага
        if not IsEnemy(plr) then
            HideAllESP(plr)
            continue
        end

        -- Проверка на Humanoid
        local humanoid = Humanoids[plr]
        if not humanoid or not humanoid.Parent then
            if not UpdateHumanoid(plr) then
                HideAllESP(plr)
                continue
            end
            humanoid = Humanoids[plr]
        end

        -- Получаем здоровье
        local health, maxHealth = GetSafeHealthValues(humanoid)
        if health <= 0 or maxHealth <= 0 then
            HideAllESP(plr)
            continue
        end

        -- Проверяем видимость (исправленная проверка)
        local onScreen, rootPos = IsOnScreen(hrp.Position)
        local headOnScreen, headPos = IsOnScreen(head.Position + Vector3.new(0, 0.5, 0))
        
        if not onScreen or not headOnScreen then
            HideAllESP(plr)
            continue
        end

        -- Проверка дистанции
        local distance = (Camera.CFrame.Position - hrp.Position).Magnitude
        if distance > ESP.Settings.MaxRenderDistance then
            HideAllESP(plr)
            continue
        end

        -- Рассчитываем размеры
        local legPos = hrp.Position - Vector3.new(0, 3, 0)
        local legOnScreen, legScreenPos = IsOnScreen(legPos)
        
        if not legOnScreen then
            legScreenPos = Vector3.new(rootPos.X, rootPos.Y + 100, rootPos.Z)
        end

        local height = math.abs(headPos.Y - legScreenPos.Y)
        local width = height * 0.55
        
        -- Защита от слишком маленьких размеров
        if height < 10 or width < 5 then
            HideAllESP(plr)
            continue
        end

        local healthPercent = health / maxHealth

        -- Обновляем все элементы
        if ESP.Settings.EspBox and box then
            box.Size = Vector2.new(width, height)
            box.Position = Vector2.new(rootPos.X - width/2, rootPos.Y - height/2)
            box.Color = ESP.Settings.BoxColor
            box.Thickness = ESP.Settings.BoxThickness
            box.Transparency = ESP.Settings.Transparency
            box.Visible = true
        elseif box then
            box.Visible = false
        end

        if ESP.Settings.EspName and Names[plr] then
            Names[plr].Position = Vector2.new(rootPos.X, rootPos.Y - height/2 - 20)
            Names[plr].Color = ESP.Settings.NameColor
            Names[plr].OutlineColor = ESP.Settings.OutlineColor
            Names[plr].Visible = true
        elseif Names[plr] then
            Names[plr].Visible = false
        end

        if ESP.Settings.EspHealthBar and HealthBars[plr] then
            local barWidth = ESP.Settings.HealthBarWidth
            local barHeight = height
            local barX = rootPos.X - width/2 - barWidth - 2
            local barY = rootPos.Y - height/2

            local bg = HealthBars[plr].bg
            local fill = HealthBars[plr].fill

            if bg then
                bg.Size = Vector2.new(barWidth, barHeight)
                bg.Position = Vector2.new(barX, barY)
                bg.Visible = true
            end

            if fill then
                local fillHeight = barHeight * healthPercent
                fillHeight = math.max(0, math.min(barHeight, fillHeight))
                
                fill.Color = GetHealthColor(healthPercent)
                fill.Size = Vector2.new(barWidth, fillHeight)
                fill.Position = Vector2.new(barX, barY + (barHeight - fillHeight))
                fill.Visible = true
            end
        elseif HealthBars[plr] then
            if HealthBars[plr].bg then HealthBars[plr].bg.Visible = false end
            if HealthBars[plr].fill then HealthBars[plr].fill.Visible = false end
        end

        if ESP.Settings.EspHealthText and HealthTexts[plr] then
            HealthTexts[plr].Color = GetHealthColor(healthPercent)
            HealthTexts[plr].OutlineColor = ESP.Settings.OutlineColor
            HealthTexts[plr].Text = string.format("%d/%d", math.floor(health), math.floor(maxHealth))
            HealthTexts[plr].Position = Vector2.new(rootPos.X - width/2 - 35, rootPos.Y)
            HealthTexts[plr].Visible = true
        elseif HealthTexts[plr] then
            HealthTexts[plr].Visible = false
        end
    end
end)

-- Подключаем события
Players.PlayerAdded:Connect(OnPlayerAdded)
Players.PlayerRemoving:Connect(RemoveESP)

-- Обрабатываем уже существующих игроков
for _, plr in Players:GetPlayers() do
    if plr ~= LocalPlayer or ESP.Settings.ShowSelf then
        OnPlayerAdded(plr)
    end
end

print("ESP loaded with optimized rendering!")

return ESP
