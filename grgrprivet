local ESP = {}
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- Настройки ESP
ESP.Settings = {
    Enabled = true,
    EspBox = true,
    EspName = true,
    EspHealthBar = true,
    EspHealthText = true,
    BoxColor = Color3.fromRGB(255, 0, 0),
    NameColor = Color3.fromRGB(255, 255, 255),
    HealthBarWidth = 6,
    OutlineColor = Color3.fromRGB(0, 0, 0),
    Transparency = 1,
    ShowTeammates = false,
    ShowEnemies = true,
    ShowSelf = false,
    BoxThickness = 1.6,
    MaxRenderDistance = 1000,
    UpdateRate = 30,
}

-- Внутренние переменные
local Boxes = {}
local Names = {}
local HealthBars = {}
local HealthTexts = {}
local Humanoids = {}
local Connections = {}
local PlayerData = {}
local PlayerState = {}
local PendingDestroy = {}
local CharacterParts = {}

-- Кэш для оптимизации
local Cache = {
    ViewportSize = Vector2.new(0, 0),
    CameraPos = Vector3.new(0, 0, 0),
    IsEnabled = true,
}

-- Функция для проверки, враг ли игрок
local function IsEnemy(plr)
    if plr == LocalPlayer then 
        return ESP.Settings.ShowSelf
    end

    local myChar = LocalPlayer.Character
    local theirChar = plr.Character
    if not myChar or not theirChar then return false end

    local myTeam = myChar.Parent and myChar.Parent.Name or "Enemy"
    local theirTeam = theirChar.Parent and theirChar.Parent.Name or "Enemy"
    
    return myTeam ~= theirTeam
end

-- Получение Humanoid
local function GetHumanoid(character)
    return character and character:FindFirstChildOfClass("Humanoid")
end

-- Очистка данных
local function ClearPlayerData(plr)
    Humanoids[plr] = nil
    PlayerData[plr] = nil
    CharacterParts[plr] = nil
end

-- Очистка соединений
local function ClearConnections(plr, keepCharAdded)
    if Connections[plr] then
        local charAddedConn = keepCharAdded and Connections[plr].charAdded
        
        for name, conn in pairs(Connections[plr]) do
            if name ~= "charAdded" or not keepCharAdded then
                pcall(conn.Disconnect, conn)
            end
        end
        
        Connections[plr] = keepCharAdded and {charAdded = charAddedConn} or nil
    end
end

-- Удаление ESP
local function DestroyESP(plr)
    local function safeRemove(obj)
        if obj then pcall(obj.Remove, obj) end
    end

    safeRemove(Boxes[plr])
    safeRemove(Names[plr])
    
    if HealthBars[plr] then
        safeRemove(HealthBars[plr].bg)
        safeRemove(HealthBars[plr].fill)
    end
    safeRemove(HealthTexts[plr])
    
    Boxes[plr] = nil
    Names[plr] = nil
    HealthBars[plr] = nil
    HealthTexts[plr] = nil
    
    ClearPlayerData(plr)
    ClearConnections(plr, true)
    PlayerState[plr] = "dead"
end

-- Создание ESP
local function CreateESP(plr)
    if Boxes[plr] then return end

    local box = Drawing.new("Square")
    box.Thickness = ESP.Settings.BoxThickness
    box.Filled = false
    box.Color = ESP.Settings.BoxColor
    box.Transparency = ESP.Settings.Transparency
    box.Visible = false
    Boxes[plr] = box

    local nameTag = Drawing.new("Text")
    nameTag.Text = plr.Name
    nameTag.Size = 16
    nameTag.Color = ESP.Settings.NameColor
    nameTag.Center = true
    nameTag.Outline = true
    nameTag.OutlineColor = ESP.Settings.OutlineColor
    nameTag.Visible = false
    Names[plr] = nameTag

    local healthBarBg = Drawing.new("Square")
    healthBarBg.Thickness = 1
    healthBarBg.Filled = true
    healthBarBg.Color = Color3.fromRGB(0, 0, 0)
    healthBarBg.Transparency = 0.7
    healthBarBg.Visible = false
    
    local healthBarFill = Drawing.new("Square")
    healthBarFill.Thickness = 1
    healthBarFill.Filled = true
    healthBarFill.Color = Color3.fromRGB(0, 255, 0)
    healthBarFill.Transparency = 0.7
    healthBarFill.Visible = false
    
    HealthBars[plr] = {bg = healthBarBg, fill = healthBarFill}

    local healthText = Drawing.new("Text")
    healthText.Size = 14
    healthText.Color = Color3.fromRGB(255, 255, 255)
    healthText.Center = true
    healthText.Outline = true
    healthText.OutlineColor = ESP.Settings.OutlineColor
    healthText.Visible = false
    HealthTexts[plr] = healthText
    
    PlayerState[plr] = "alive"
end

-- Цвета здоровья
local HealthColors = {
    [1] = Color3.fromRGB(0, 255, 0),
    [2] = Color3.fromRGB(255, 255, 0),
    [3] = Color3.fromRGB(255, 100, 0),
    [4] = Color3.fromRGB(255, 0, 0),
}

local function GetHealthColor(percent)
    if percent > 0.6 then return HealthColors[1]
    elseif percent > 0.3 then return HealthColors[2]
    elseif percent > 0.1 then return HealthColors[3]
    else return HealthColors[4] end
end

-- Получение здоровья
local function GetHealthValues(humanoid)
    if not humanoid then return 0, 100 end
    
    local success, maxHealth = pcall(function() return humanoid.MaxHealth end)
    local success2, health = pcall(function() return humanoid.Health end)
    
    maxHealth = (success and maxHealth > 0) and maxHealth or 100
    health = (success2 and health > 0) and health or 0
    
    return health, maxHealth
end

-- Конвертация 3D в 2D
local function WorldToScreen(position)
    local success, result = pcall(Camera.WorldToViewportPoint, Camera, position)
    
    if success and result then
        return {
            X = result.X,
            Y = result.Y,
            Z = result.Z,
            Visible = result.Z > 0.1
        }
    end
    
    return {
        X = -1000,
        Y = -1000,
        Z = -1,
        Visible = false
    }
end

-- ИСПРАВЛЕННАЯ ПРОВЕРКА ВИДИМОСТИ
local function IsOnScreen(screenPos, viewportSize)
    -- Проверяем что точка перед камерой
    if not screenPos.Visible or screenPos.Z <= 0.1 then
        return false
    end
    
    -- Проверяем что точка в пределах экрана (без запаса)
    if screenPos.X < 0 or screenPos.X > viewportSize.X then
        return false
    end
    
    if screenPos.Y < 0 or screenPos.Y > viewportSize.Y then
        return false
    end
    
    return true
end

-- Обновление Humanoid
local function UpdateHumanoid(plr)
    local char = plr.Character
    if char then
        local newHumanoid = GetHumanoid(char)
        if newHumanoid and newHumanoid.Health > 0 then
            Humanoids[plr] = newHumanoid
            return true
        end
    end
    Humanoids[plr] = nil
    return false
end

-- Обработка смерти
local function OnPlayerDied(plr)
    PendingDestroy[plr] = true
end

-- Обработка добавления персонажа
local function OnCharacterAdded(plr, char)
    CreateESP(plr)
    ClearConnections(plr, true)
    CharacterParts[plr] = nil
    
    local humanoid = GetHumanoid(char)
    if humanoid then
        Connections[plr] = Connections[plr] or {}
        Connections[plr].died = humanoid.Died:Connect(function()
            OnPlayerDied(plr)
        end)
        
        Connections[plr].healthChanged = humanoid:GetPropertyChangedSignal("Health"):Connect(function()
            PlayerData[plr] = PlayerData[plr] or {}
            PlayerData[plr].healthChanged = true
        end)
    end

    Connections[plr].charRemoved = char.AncestryChanged:Connect(function()
        if not char.Parent then
            OnPlayerDied(plr)
        end
    end)
    
    UpdateHumanoid(plr)
end

-- Обработка добавления игрока
local function OnPlayerAdded(plr)
    if plr == LocalPlayer then return end

    local charAddedConn = plr.CharacterAdded:Connect(function(char)
        OnCharacterAdded(plr, char)
    end)

    Connections[plr] = {charAdded = charAddedConn}
    PlayerState[plr] = plr.Character and "alive" or "respawning"
    
    if plr.Character then
        OnCharacterAdded(plr, plr.Character)
    end
end

-- Основной цикл
local lastUpdate = 0
local updateInterval = 1/30

RunService.Heartbeat:Connect(function()
    local currentTime = tick()
    
    -- Ограничиваем частоту
    if currentTime - lastUpdate < updateInterval then
        return
    end
    lastUpdate = currentTime
    
    -- Кэшируем значения
    Cache.ViewportSize = Camera.ViewportSize
    Cache.CameraPos = Camera.CFrame.Position
    Cache.IsEnabled = ESP.Settings.Enabled
    
    -- Удаляем помеченных
    for plr in pairs(PendingDestroy) do
        DestroyESP(plr)
        PendingDestroy[plr] = nil
    end
    
    -- Основной цикл
    for plr, box in pairs(Boxes) do
        if plr == LocalPlayer then continue end
        
        -- Проверка состояния
        if PlayerState[plr] ~= "alive" or not Cache.IsEnabled then
            if box.Visible then
                box.Visible = false
                if Names[plr] then Names[plr].Visible = false end
                if HealthBars[plr] then
                    if HealthBars[plr].bg then HealthBars[plr].bg.Visible = false end
                    if HealthBars[plr].fill then HealthBars[plr].fill.Visible = false end
                end
                if HealthTexts[plr] then HealthTexts[plr].Visible = false end
            end
            continue
        end
        
        -- Получаем персонажа
        local char = plr.Character
        if not char or not char.Parent then
            if box.Visible then box.Visible = false end
            continue
        end
        
        -- Получаем части тела
        local hrp = char:FindFirstChild("HumanoidRootPart") or 
                    char:FindFirstChild("Torso") or 
                    char:FindFirstChild("UpperTorso")
        local head = char:FindFirstChild("Head")
        
        if not hrp or not head then
            if box.Visible then box.Visible = false end
            continue
        end
        
        -- Проверка дистанции
        local distance = (Cache.CameraPos - hrp.Position).Magnitude
        if distance > ESP.Settings.MaxRenderDistance then
            if box.Visible then box.Visible = false end
            continue
        end
        
        -- Проверка на врага
        if not IsEnemy(plr) then
            if box.Visible then box.Visible = false end
            continue
        end
        
        -- Получаем позиции на экране
        local rootScreen = WorldToScreen(hrp.Position)
        local headScreen = WorldToScreen(head.Position + Vector3.new(0, 0.5, 0))
        local legScreen = WorldToScreen(hrp.Position - Vector3.new(0, 3, 0))
        
        -- СТРОГАЯ ПРОВЕРКА ВИДИМОСТИ
        local rootVisible = IsOnScreen(rootScreen, Cache.ViewportSize)
        local headVisible = IsOnScreen(headScreen, Cache.ViewportSize)
        local legVisible = IsOnScreen(legScreen, Cache.ViewportSize)
        
        -- Если ни одна точка не видна на экране - прячем ESP
        if not rootVisible and not headVisible and not legVisible then
            if box.Visible then
                box.Visible = false
                if Names[plr] then Names[plr].Visible = false end
                if HealthBars[plr] then
                    if HealthBars[plr].bg then HealthBars[plr].bg.Visible = false end
                    if HealthBars[plr].fill then HealthBars[plr].fill.Visible = false end
                end
                if HealthTexts[plr] then HealthTexts[plr].Visible = false end
            end
            continue
        end
        
        -- Проверка Humanoid
        local humanoid = Humanoids[plr]
        if not humanoid or not humanoid.Parent then
            if not UpdateHumanoid(plr) then
                if box.Visible then box.Visible = false end
                continue
            end
            humanoid = Humanoids[plr]
        end
        
        -- Получаем здоровье
        local health, maxHealth = GetHealthValues(humanoid)
        if health <= 0 then
            if box.Visible then box.Visible = false end
            continue
        end
        
        -- Используем доступные координаты
        local finalRoot = rootVisible and rootScreen or (headVisible and headScreen or legScreen)
        local finalHead = headVisible and headScreen or (rootVisible and rootScreen or legScreen)
        local finalLeg = legVisible and legScreen or (rootVisible and rootScreen or headScreen)
        
        -- Корректировка высоты
        if not headVisible and rootVisible then
            finalHead.Y = finalRoot.Y - 50
        end
        if not legVisible and rootVisible then
            finalLeg.Y = finalRoot.Y + 50
        end
        
        -- Вычисляем размеры
        local height = math.abs(finalHead.Y - finalLeg.Y)
        local width = height * 0.55
        
        -- Защита от слишком маленьких размеров
        if height < 10 or width < 5 then
            if box.Visible then box.Visible = false end
            continue
        end
        
        local healthPercent = health / maxHealth
        
        -- Обновляем все элементы
        if ESP.Settings.EspBox then
            box.Size = Vector2.new(width, height)
            box.Position = Vector2.new(finalRoot.X - width/2, finalRoot.Y - height/2)
            if not box.Visible then box.Visible = true end
        end
        
        if ESP.Settings.EspName and Names[plr] then
            Names[plr].Position = Vector2.new(finalRoot.X, finalRoot.Y - height/2 - 20)
            if not Names[plr].Visible then Names[plr].Visible = true end
        end
        
        if ESP.Settings.EspHealthBar and HealthBars[plr] then
            local barWidth = ESP.Settings.HealthBarWidth
            local barX = finalRoot.X - width/2 - barWidth - 2
            local barY = finalRoot.Y - height/2
            
            local bg = HealthBars[plr].bg
            local fill = HealthBars[plr].fill
            
            if bg then
                bg.Size = Vector2.new(barWidth, height)
                bg.Position = Vector2.new(barX, barY)
                if not bg.Visible then bg.Visible = true end
            end
            
            if fill then
                local fillHeight = height * healthPercent
                fill.Color = GetHealthColor(healthPercent)
                fill.Size = Vector2.new(barWidth, fillHeight)
                fill.Position = Vector2.new(barX, barY + (height - fillHeight))
                if not fill.Visible then fill.Visible = true end
            end
        end
        
        if ESP.Settings.EspHealthText and HealthTexts[plr] then
            HealthTexts[plr].Text = string.format("%d/%d", math.floor(health), math.floor(maxHealth))
            HealthTexts[plr].Position = Vector2.new(finalRoot.X - width/2 - 35, finalRoot.Y)
            if not HealthTexts[plr].Visible then HealthTexts[plr].Visible = true end
        end
    end
end)

-- Подключаем события
Players.PlayerAdded:Connect(OnPlayerAdded)
Players.PlayerRemoving:Connect(DestroyESP)

-- Обрабатываем существующих игроков
for _, plr in Players:GetPlayers() do
    if plr ~= LocalPlayer then
        OnPlayerAdded(plr)
    end
end

print("ESP loaded - Strict visibility check")
print("Current CameraMode:", LocalPlayer and LocalPlayer.CameraMode)

return ESP
