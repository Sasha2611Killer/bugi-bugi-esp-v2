--// Made by Blissful#4992
--// Modified for Library-style usage with correct Name ESP positioning

local ESP = {}
local ESP_Instances = {}

--// Settings (can be modified after loading)
ESP.Boxes = true
ESP.Names = true
ESP.ShowDistance = true
ESP.Box_Color = Color3.fromRGB(0, 255, 50)
ESP.Box_Thickness = 1.4
ESP.Box_Transparency = 1
ESP.Name_Color = Color3.fromRGB(255, 255, 255)
ESP.Name_Size = 19
ESP.Name_Center = true
ESP.Name_Outline = true
ESP.Name_Font = 2
ESP.BoxShift = CFrame.new(0, -1.5, 0) -- Смещение бокса как в оригинале
ESP.BoxSize = Vector3.new(4, 6, 0) -- Размер бокса как в оригинале
ESP.Distance_Offset = 14
ESP.Autothickness = false
ESP.Team_Check = false
ESP.Team_Color_Enemy = Color3.fromRGB(227, 52, 52)
ESP.Team_Color_Friendly = Color3.fromRGB(88, 217, 24)
ESP.TeamMates = true
ESP.FaceCamera = false -- Поворачивать бокс лицом к камере

--// Internal variables
local workspace = game:GetService("Workspace")
local player = game:GetService("Players").LocalPlayer
local camera = workspace.CurrentCamera
local players = game:GetService("Players")
local runService = game:GetService("RunService")

--// Helper functions
local function WorldToViewportPoint(point)
    return camera:WorldToViewportPoint(point)
end

local function NewLine()
    local line = Drawing.new("Line")
    line.Visible = false
    line.From = Vector2.new(0, 0)
    line.To = Vector2.new(1, 1)
    line.Color = ESP.Box_Color
    line.Thickness = ESP.Box_Thickness
    line.Transparency = ESP.Box_Transparency
    return line
end

local function NewText()
    local text = Drawing.new("Text")
    text.Visible = false
    text.Text = ""
    text.Color = ESP.Name_Color
    text.Size = ESP.Name_Size
    text.Center = ESP.Name_Center
    text.Outline = ESP.Name_Outline
    text.Font = ESP.Name_Font
    return text
end

--// Team check functions
local function GetTeam(p)
    return p and p.Team
end

local function IsTeamMate(p)
    return GetTeam(p) == GetTeam(player)
end

--// Main ESP function for each player
local function createESPForPlayer(plr)
    if plr == player then return end
    
    --// Create drawing objects
    local instances = {
        -- 12 lines for 3D box
        line1 = NewLine(),
        line2 = NewLine(),
        line3 = NewLine(),
        line4 = NewLine(),
        line5 = NewLine(),
        line6 = NewLine(),
        line7 = NewLine(),
        line8 = NewLine(),
        line9 = NewLine(),
        line10 = NewLine(),
        line11 = NewLine(),
        line12 = NewLine(),
        -- Name text
        nameText = NewText(),
        -- Distance text
        distanceText = NewText()
    }
    
    ESP_Instances[plr] = instances
    
    --// Update function for render loop
    local function updateESP()
        local connection
        connection = runService.RenderStepped:Connect(function()
            -- Check if player is valid
            if plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Head") and plr.Character.Humanoid.Health > 0 then
                
                -- Team check
                if not ESP.TeamMates and IsTeamMate(plr) then
                    for i = 1, 12 do
                        instances["line"..i].Visible = false
                    end
                    instances.nameText.Visible = false
                    instances.distanceText.Visible = false
                    return
                end
                
                local rootPart = plr.Character.HumanoidRootPart
                local head = plr.Character.Head
                
                -- Calculate CFrame with FaceCamera option (как в оригинале)
                local cf = rootPart.CFrame
                if ESP.FaceCamera then
                    cf = CFrame.new(cf.p, camera.CFrame.p)
                end
                
                -- Apply BoxShift (как в оригинале)
                cf = cf * ESP.BoxShift
                
                -- Calculate positions for all box corners (как в оригинале)
                local size = ESP.BoxSize
                local locs = {
                    TopLeft = cf * CFrame.new(size.X/2, size.Y/2, 0),
                    TopRight = cf * CFrame.new(-size.X/2, size.Y/2, 0),
                    BottomLeft = cf * CFrame.new(size.X/2, -size.Y/2, 0),
                    BottomRight = cf * CFrame.new(-size.X/2, -size.Y/2, 0),
                    TagPos = cf * CFrame.new(0, size.Y/2, 0),  -- Позиция для имени (сверху бокса)
                    Torso = cf
                }
                
                -- Convert all positions to screen coordinates
                local TopLeft, Vis1 = WorldToViewportPoint(locs.TopLeft.p)
                local TopRight, Vis2 = WorldToViewportPoint(locs.TopRight.p)
                local BottomLeft, Vis3 = WorldToViewportPoint(locs.BottomLeft.p)
                local BottomRight, Vis4 = WorldToViewportPoint(locs.BottomRight.p)
                local TagPos, Vis5 = WorldToViewportPoint(locs.TagPos.p)
                
                -- Determine if any part is visible
                local anyVisible = Vis1 or Vis2 or Vis3 or Vis4 or Vis5
                
                if anyVisible then
                    -- Determine colors based on team check
                    local boxColor = ESP.Box_Color
                    local nameColor = ESP.Name_Color
                    
                    if ESP.Team_Check then
                        if IsTeamMate(plr) then
                            boxColor = ESP.Team_Color_Friendly
                            nameColor = ESP.Team_Color_Friendly
                        else
                            boxColor = ESP.Team_Color_Enemy
                            nameColor = ESP.Team_Color_Enemy
                        end
                    end
                    
                    -- Update thickness based on distance
                    local thickness = ESP.Box_Thickness
                    if ESP.Autothickness and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                        local distance = (player.Character.HumanoidRootPart.Position - rootPart.Position).Magnitude
                        thickness = math.clamp(1/distance * 100, 0.1, 4)
                    end
                    
                    -- Update box lines if enabled
                    if ESP.Boxes then
                        -- Top square
                        instances.line1.From = Vector2.new(TopLeft.X, TopLeft.Y)
                        instances.line1.To = Vector2.new(TopRight.X, TopRight.Y)
                        instances.line2.From = Vector2.new(TopRight.X, TopRight.Y)
                        instances.line2.To = Vector2.new(BottomRight.X, BottomRight.Y)
                        instances.line3.From = Vector2.new(BottomRight.X, BottomRight.Y)
                        instances.line3.To = Vector2.new(BottomLeft.X, BottomLeft.Y)
                        instances.line4.From = Vector2.new(BottomLeft.X, BottomLeft.Y)
                        instances.line4.To = Vector2.new(TopLeft.X, TopLeft.Y)
                        
                        -- Bottom square (для 3D эффекта, но можно отключить если не нужно)
                        -- В оригинале они используют Quad, а мы оставим 2D прямоугольник
                        
                        -- Apply properties to all lines
                        for i = 1, 4 do
                            local line = instances["line"..i]
                            line.Color = boxColor
                            line.Thickness = thickness
                            line.Transparency = ESP.Box_Transparency
                            line.Visible = true
                        end
                        
                        -- Hide unused lines
                        for i = 5, 12 do
                            instances["line"..i].Visible = false
                        end
                    else
                        for i = 1, 12 do
                            instances["line"..i].Visible = false
                        end
                    end
                    
                    -- Update name text if enabled and tag position is visible
                    if ESP.Names and Vis5 then
                        -- Name (позиция из TagPos как в оригинале)
                        instances.nameText.Position = Vector2.new(TagPos.X, TagPos.Y)
                        instances.nameText.Text = plr.Name
                        instances.nameText.Color = nameColor
                        instances.nameText.Size = ESP.Name_Size
                        instances.nameText.Center = ESP.Name_Center
                        instances.nameText.Outline = ESP.Name_Outline
                        instances.nameText.Font = ESP.Name_Font
                        instances.nameText.Visible = true
                        
                        -- Distance (под именем как в оригинале)
                        if ESP.ShowDistance then
                            local distance = math.floor((camera.CFrame.p - rootPart.Position).Magnitude)
                            instances.distanceText.Position = Vector2.new(TagPos.X, TagPos.Y + ESP.Distance_Offset)
                            instances.distanceText.Text = distance .. "m"
                            instances.distanceText.Color = nameColor
                            instances.distanceText.Size = ESP.Name_Size - 2
                            instances.distanceText.Center = ESP.Name_Center
                            instances.distanceText.Outline = ESP.Name_Outline
                            instances.distanceText.Font = ESP.Name_Font
                            instances.distanceText.Visible = true
                        else
                            instances.distanceText.Visible = false
                        end
                    else
                        instances.nameText.Visible = false
                        instances.distanceText.Visible = false
                    end
                    
                else
                    for i = 1, 12 do
                        instances["line"..i].Visible = false
                    end
                    instances.nameText.Visible = false
                    instances.distanceText.Visible = false
                end
            else
                for i = 1, 12 do
                    instances["line"..i].Visible = false
                end
                instances.nameText.Visible = false
                instances.distanceText.Visible = false
                
                if not players:FindFirstChild(plr.Name) then
                    connection:Disconnect()
                    ESP_Instances[plr] = nil
                end
            end
        end)
    end
    
    coroutine.wrap(updateESP)()
end

--// Initialize ESP for existing players
for _, plr in pairs(players:GetPlayers()) do
    createESPForPlayer(plr)
end

--// Handle new players joining
players.PlayerAdded:Connect(function(plr)
    createESPForPlayer(plr)
end)

--// Handle players leaving
players.PlayerRemoving:Connect(function(plr)
    if ESP_Instances[plr] then
        for _, instance in pairs(ESP_Instances[plr]) do
            instance:Remove()
        end
        ESP_Instances[plr] = nil
    end
end)

--// Return the ESP table for external use
return ESP
